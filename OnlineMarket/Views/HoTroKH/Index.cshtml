@{
    ViewBag.Title = "Trung tâm hỗ trợ - Fruit Store";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Inter', sans-serif;
    }

    .brand-color {
        color: #05a569 !important;
    }

    .bg-brand {
        background-color: #05a569 !important;
    }

    /* Hero Section */
    .support-hero {
        background: linear-gradient(135deg, #05a569 0%, #048b58 100%);
        padding: 60px 0;
        text-align: center;
        color: white;
        margin-bottom: -50px;
        padding-bottom: 90px;
    }

    .search-support {
        max-width: 600px;
        margin: 0 auto;
        position: relative;
    }

        .search-support input {
            border-radius: 50px;
            padding: 15px 25px 15px 50px;
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            font-size: 15px;
        }

            .search-support input:focus {
                box-shadow: 0 10px 25px rgba(0,0,0,0.15);
                outline: none;
            }

    .search-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #888;
    }

    /* Contact Cards */
    .contact-card {
        background: #ffffff;
        border-radius: 8px;
        padding: 30px 20px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        border: 1px solid #ebebeb;
        height: 100%;
        transition: transform 0.2s;
    }

        .contact-card:hover {
            transform: translateY(-5px);
            border-color: #05a569;
        }

    .contact-icon-wrapper {
        width: 60px;
        height: 60px;
        background: #f0fdf4;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: #05a569;
    }

    .contact-title {
        font-size: 16px;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    .contact-desc {
        color: #666;
        font-size: 14px;
        margin-bottom: 15px;
        line-height: 1.6;
    }

    .contact-info {
        font-size: 16px;
        font-weight: 600;
        color: #05a569;
        text-decoration: none;
    }

    /* FAQ Section */
    .section-title {
        font-size: 22px;
        font-weight: 700;
        color: #333;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
    }

    .faq-accordion .accordion-item {
        border: 1px solid #ebebeb;
        border-radius: 8px !important;
        margin-bottom: 12px;
        overflow: hidden;
    }

    .faq-accordion .accordion-button {
        font-weight: 600;
        color: #444;
        padding: 18px 20px;
        background-color: #fff;
        box-shadow: none;
    }

        .faq-accordion .accordion-button:not(.collapsed) {
            color: #05a569;
            background-color: #f0fdf4;
        }

        .faq-accordion .accordion-button::after {
            background-size: 1rem;
        }

    .faq-accordion .accordion-body {
        color: #555;
        font-size: 14.5px;
        line-height: 1.7;
        padding: 20px;
        background-color: #fff;
    }

    /* Form Styles */
    .form-card {
        background: #fff;
        padding: 40px;
        border-radius: 8px;
        border: 1px solid #ebebeb;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .form-control, .form-select {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 12px 15px;
        font-size: 14.5px;
        background-color: #fbfbfc;
    }

        .form-control:focus, .form-select:focus {
            border-color: #05a569;
            box-shadow: 0 0 0 0.2rem rgba(5, 165, 105, 0.15);
            background-color: #fff;
        }

    .form-label {
        font-weight: 500;
        color: #444;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .btn-submit {
        background-color: #05a569;
        color: white;
        border: none;
        padding: 14px 30px;
        border-radius: 6px;
        font-weight: 600;
        width: 100%;
        transition: 0.2s;
    }

        .btn-submit:hover {
            background-color: #048b58;
        }
</style>

<div class="support-hero">
    <div class="container">
        <h1 class="fw-bold mb-3" style="font-size: 32px;">Xin chào, chúng tôi có thể giúp gì cho bạn?</h1>
        <p class="mb-4" style="opacity: 0.9;">Nhập từ khóa tìm kiếm hoặc xem các câu hỏi thường gặp bên dưới</p>

        <div class="search-support">
            <svg class="search-icon" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input type="text" class="form-control form-control-lg" placeholder="Ví dụ: Phí vận chuyển, chính sách đổi trả...">
        </div>
    </div>
</div>

<div class="container pb-5">

    <div class="row g-4 mb-5 position-relative" style="z-index: 10;">
        <div class="col-lg-4 col-md-6">
            <div class="contact-card">
                <div class="contact-icon-wrapper">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
                </div>
                <h3 class="contact-title">Gọi Hotline</h3>
                <p class="contact-desc">Hỗ trợ nhanh chóng các vấn đề về đơn hàng, hủy đơn hoặc phản ánh dịch vụ.</p>
                <a href="tel:0326371255" class="contact-info">032 637 1255</a>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="contact-card">
                <div class="contact-icon-wrapper">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2" ry="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                </div>
                <h3 class="contact-title">Gửi Email</h3>
                <p class="contact-desc">Dành cho các yêu cầu hợp tác, khiếu nại hoặc cần đính kèm hình ảnh/hóa đơn.</p>
                <a href="mailto:support@fruitstore.vn" class="contact-info">support@fruitstore.vn</a>
            </div>
        </div>

        <div class="col-lg-4 col-md-6 d-none d-lg-block">
            <div class="contact-card">
                <div class="contact-icon-wrapper">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
                </div>
                <h3 class="contact-title">Đến Cửa Hàng</h3>
                <p class="contact-desc">Đến trực tiếp cửa hàng để được xem sản phẩm tươi sạch và hỗ trợ nhanh nhất.</p>
                <span class="contact-info text-dark" style="font-size: 15px;">Quận Bình Tân, TP.HCM</span>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <div class="col-lg-6">
            <h2 class="section-title">
                <svg width="24" height="24" class="me-2 brand-color" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                Câu Hỏi Thường Gặp
            </h2>

            <div class="accordion faq-accordion" id="faqAccordion">

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                            1. Thời gian giao hàng mất bao lâu?
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Đối với khu vực nội thành TP.HCM, chúng tôi hỗ trợ giao hàng hỏa tốc trong vòng <strong>2 giờ</strong>. Các khu vực ngoại thành hoặc tỉnh lân cận thời gian giao hàng dự kiến từ 1 - 2 ngày làm việc.
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingTwo">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                            2. Tôi có thể kiểm tra hàng trước khi nhận không?
                        </button>
                    </h2>
                    <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Vì sản phẩm là nông sản và trái cây tươi, Fruit Store <strong>luôn khuyến khích</strong> khách hàng kiểm tra kỹ trạng thái sản phẩm ngay khi nhân viên giao hàng mang tới. Nếu có dập nát hoặc hỏng, bạn có quyền từ chối nhận hàng.
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingThree">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                            3. Cửa hàng có hỗ trợ xuất hóa đơn VAT không?
                        </button>
                    </h2>
                    <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Có. Vui lòng điền thông tin Công ty (Tên công ty, MST, Địa chỉ) vào ô <strong>Ghi chú</strong> ở bước Thanh toán. Chúng tôi sẽ gửi hóa đơn điện tử qua email cho bạn trong vòng 24h sau khi đơn hàng giao thành công.
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingFour">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour">
                            4. Chính sách đổi trả hàng như thế nào?
                        </button>
                    </h2>
                    <div id="collapseFour" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            Trong trường hợp hàng hóa bị hỏng hóc do lỗi vận chuyển hoặc không đúng mô tả, khách hàng vui lòng chụp ảnh và báo ngay qua Hotline hoặc Email trong vòng <strong>12 giờ</strong> kể từ lúc nhận hàng để được đổi trả miễn phí.
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-lg-6">
            <h2 class="section-title">
                <svg width="24" height="24" class="me-2 brand-color" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                Gửi Yêu Cầu Hỗ Trợ
            </h2>

            <div class="form-card">
                @using (Html.BeginForm("GuiYeuCau", "HoTroKH", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" name="HoTen" class="form-control" placeholder="Nhập họ tên" required value="@(Request.IsAuthenticated ? User.Identity.Name : "")">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="tel" name="SoDienThoai" class="form-control" placeholder="Nhập SĐT" required>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Chủ đề hỗ trợ</label>
                            <select name="ChuDe" class="form-select">
                                <option value="Hỏi đáp về sản phẩm">Hỏi đáp về sản phẩm</option>
                                <option value="Vấn đề về Đơn hàng/Vận chuyển">Vấn đề về Đơn hàng/Vận chuyển</option>
                                <option value="Báo lỗi khiếu nại">Báo lỗi - Khiếu nại dịch vụ</option>
                                <option value="Hợp tác kinh doanh">Liên hệ hợp tác kinh doanh</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Nội dung chi tiết <span class="text-danger">*</span></label>
                            <textarea name="NoiDung" class="form-control" rows="4" placeholder="Vui lòng mô tả chi tiết vấn đề bạn đang gặp phải (Kèm mã đơn hàng nếu có)..." required></textarea>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn-submit d-flex justify-content-center align-items-center">
                                <svg width="20" height="20" class="me-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                                Gửi Yêu Cầu
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>