                            </div>
                        </a>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-support-item">
                        <div class="quick-support-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="quick-support-text">
                            <h5>Email</h5>
                            <p class="mb-0">support@fruitstore.com</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-support-item">
                        <a href="@Url.Action("GuiYeuCau", "HoTroKH")" class="text-white text-decoration-none">
                            <div class="quick-support-icon">
                                <i class="fas fa-headset"></i>
                            </div>
                            <div class="quick-support-text">
                                <h5>Gửi Yêu Cầu</h5>
