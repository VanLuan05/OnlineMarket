                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="quick-support-item">
                        <a href="@Url.Action("Chatbox", "HoTroKH")" class="text-white text-decoration-none">
                            <div class="quick-support-icon">
                                <i class="fas fa-comments"></i>
                            </div>
                            <div class="quick-support-text">
                                <h5>Chat Online</h5>
