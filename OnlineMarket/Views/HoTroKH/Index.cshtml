        </div>

        <!-- Quick Support Bar -->
        <div class="quick-support-bar">
            <div class="row text-center">
                <div class="col-md-3 col-6">
                    <div class="quick-support-item">
                        <div class="quick-support-icon">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <div class="quick-support-text">
