</section>

<!-- Thêm CSS cho button tùy chỉnh -->
<style>
    .btn-outline-purple {
        color: #9b59b6;
        border-color: #9b59b6;
    }

        .btn-outline-purple:hover {
            background-color: #9b59b6;
            color: white;
        }

    .text-purple {
        color: #9b59b6;
    }

    .accordion-button:not(.collapsed)::after {
        filter: brightness(0) invert(1);
    }
</style>

@section scripts {
    <script>
        // Thêm hiệu ứng khi scroll đến phần tử
        document.addEventListener('DOMContentLoaded', function() {
            // Animation cho các card khi scroll
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, observerOptions);

            // Áp dụng animation cho các card
            document.querySelectorAll('.support-card').forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                observer.observe(card);
            });

            // Xử lý click cho quick support items
            document.querySelectorAll('.quick-support-item').forEach(item => {
                item.addEventListener('click', function() {
                    this.style.transform = 'translateY(-5px) scale(1.05)';
                    setTimeout(() => {
                        this.style.transform = 'translateY(-5px)';
                    }, 150);
                });
            });
        });
    </script>
}