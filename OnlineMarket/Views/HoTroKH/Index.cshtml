@{
    ViewBag.Title = "Dịch Vụ Hỗ Trợ Khách Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- CSS riêng cho trang hỗ trợ -->
<style>
    /* Customer Support Section */
    .support-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 60px 0;
    }

    .section-title {
        color: #2c3e50;
        font-weight: 700;
        margin-bottom: 50px;
        position: relative;
        padding-bottom: 15px;
    }

    .section-title:after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 80px;
        height: 4px;
        background: linear-gradient(90deg, #3498db, #2ecc71);
        border-radius: 2px;
    }

    .support-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition: all 0.4s ease;
        border: none;
        height: 100%;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }

    .support-card:before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg, var(--card-color-1), var(--card-color-2));
        z-index: 2;
    }

    .support-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }

    .support-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        font-size: 2rem;
        color: white;
        background: linear-gradient(135deg, var(--card-color-1), var(--card-color-2));
        box-shadow: 0 8px 20px rgba(var(--card-color-1-rgb), 0.3);
    }

    .support-card h4 {
        color: #2c3e50;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .support-card p {
        color: #7f8c8d;
        line-height: 1.6;
        margin-bottom: 25px;
    }

    /* Quick Support Bar */
    .quick-support-bar {
        background: linear-gradient(90deg, #3498db, #2ecc71);
        color: white;
        padding: 20px 0;
        margin-bottom: 40px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);
    }

    .quick-support-item {
        text-align: center;
        padding: 15px;
        transition: transform 0.3s ease;
    }

    .quick-support-item:hover {
        transform: translateY(-5px);
    }

    .quick-support-icon {
        font-size: 2rem;
        margin-bottom: 10px;
        display: inline-block;
    }

    .quick-support-text h5 {
        font-weight: 600;
        margin-bottom: 5px;
    }

    /* FAQ Section */
    .faq-section {
        background: white;
        border-radius: 15px;
        padding: 40px;
        margin-top: 60px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    .faq-title {
        color: #2c3e50;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f1f1f1;
    }

    .accordion-button {
        font-weight: 600;
        color: #2c3e50;
        background: #f8f9fa;
        border: none;
        box-shadow: none;
    }

    .accordion-button:not(.collapsed) {
        background: #3498db;
        color: white;
    }

    .accordion-button:focus {
        box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .support-section {
            padding: 40px 0;
        }

        .support-card {
            margin-bottom: 30px;
        }

        .quick-support-bar {
            padding: 15px 0;
        }

        .faq-section {
            padding: 25px;
        }
    }
</style>

<!-- Main Content -->
<section class="support-section">
    <div class="container">
        <!-- Page Header -->
        <div class="text-center mb-5">
            <h1 class="section-title">Dịch Vụ Hỗ Trợ Khách Hàng</h1>
