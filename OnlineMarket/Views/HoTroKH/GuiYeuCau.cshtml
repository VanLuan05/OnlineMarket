@{
    ViewBag.Title = "Gửi Yêu Cầu Hỗ Trợ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* CSS cho trang gửi yêu cầu hỗ trợ */
    .support-request-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 60px 0;
        min-height: calc(100vh - 300px);
    }

    .support-form-container {
        background: white;
        border-radius: 15px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        border: 1px solid #eaeaea;
    }

    .support-form-header {
        background: linear-gradient(135deg, #f39c12, #e67e22);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .support-form-header h2 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .support-form-header p {
        opacity: 0.9;
        font-size: 1.1rem;
    }

    .support-form-body {
        padding: 40px;
    }

    .form-label {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #f39c12;
        box-shadow: 0 0 0 0.25rem rgba(243, 156, 18, 0.25);
    }

    .form-control.is-invalid {
        border-color: #dc3545;
    }

    .form-text {
        font-size: 0.875rem;
        color: #6c757d;
    }

    .file-upload-area {
        border: 2px dashed #dee2e6;
        border-radius: 8px;
        padding: 40px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #f8f9fa;
    }

    .file-upload-area:hover {
        border-color: #f39c12;
        background: #fff9e6;
    }

    .file-upload-area i {
        font-size: 3rem;
        color: #f39c12;
        margin-bottom: 15px;
    }

    .file-upload-area.drag-over {
        border-color: #f39c12;
        background: #fff9e6;
    }

    .selected-files {
        margin-top: 15px;
    }

    .file-item {
        background: #f8f9fa;
        border-radius: 5px;
        padding: 8px 15px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .file-item i {
        color: #6c757d;
        cursor: pointer;
    }

    .file-item i:hover {
        color: #dc3545;
    }

    .priority-badge {
        font-size: 0.8rem;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .priority-low {
        background-color: #d4edda;
        color: #155724;
    }

    .priority-medium {
        background-color: #fff3cd;
        color: #856404;
    }

    .priority-high {
        background-color: #f8d7da;
        color: #721c24;
    }

    .urgent {
        background-color: #dc3545;
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 600;
        display: inline-block;
        margin-left: 10px;
    }

    .processing-info {
        background: #e8f4fd;
        border-left: 4px solid #3498db;
        padding: 20px;
        border-radius: 5px;
        margin-top: 30px;
    }

    .processing-info h5 {
        color: #3498db;
        margin-bottom: 10px;
    }

    /* Responsive Design */
   @@media (max-width: 768px) {
        .support-form-body {
            padding: 25px;
        }

        .support-form-header {
            padding: 20px;
        }

        .support-form-header h2 {
            font-size: 1.5rem;
        }
    }

    /* Custom checkbox */
    .form-check-input:checked {
        background-color: #f39c12;
        border-color: #f39c12;
    }

    .btn-submit {
        background: linear-gradient(135deg, #f39c12, #e67e22);
        border: none;
        color: white;
        padding: 12px 40px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
        font-size: 1.1rem;
    }

    .btn-submit:hover {
        background: linear-gradient(135deg, #e67e22, #d35400);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(243, 156, 18, 0.3);
    }

    .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .back-link {
        color: #6c757d;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        margin-top: 20px;
    }

    .back-link:hover {
        color: #f39c12;
    }
</style>

<section class="support-request-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Breadcrumb Navigation -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "HoTroKH")">Hỗ trợ khách hàng</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Gửi yêu cầu hỗ trợ</li>
                    </ol>
                </nav>

                <div class="support-form-container">
                    <!-- Header -->
                    <div class="support-form-header">
                        <h2><i class="fas fa-headset me-2"></i>Gửi Yêu Cầu Hỗ Trợ</h2>
                        <p>Điền thông tin bên dưới, chúng tôi sẽ liên hệ lại với bạn trong thời gian sớm nhất</p>
                    </div>

                    <!-- Form Body -->
                    <div class="support-form-body">
                        <form id="supportRequestForm" novalidate>
                            <!-- Thông tin cá nhân -->
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <h4 class="mb-4"><i class="fas fa-user-circle me-2 text-primary"></i>Thông tin cá nhân</h4>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label for="fullName" class="form-label">
                                        Họ và tên <span class="text-danger">*</span>
                                    </label>
                                    <input type="text" class="form-control" id="fullName" name="fullName"
                                           placeholder="Nhập họ và tên của bạn" required>
                                    <div class="invalid-feedback">
                                        Vui lòng nhập họ và tên
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="phoneNumber" class="form-label">
                                        Số điện thoại <span class="text-danger">*</span>
                                    </label>
                                    <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber"
                                           placeholder="Nhập số điện thoại" required pattern="[0-9]{10,11}">
                                    <div class="invalid-feedback">
                                        Vui lòng nhập số điện thoại hợp lệ (10-11 số)
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">
                                        Email <span class="text-danger">*</span>
                                    </label>
                                    <input type="email" class="form-control" id="email" name="email"
                                           placeholder="email@example.com" required>
                                    <div class="invalid-feedback">
                                        Vui lòng nhập địa chỉ email hợp lệ
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="orderNumber" class="form-label">Mã đơn hàng (nếu có)</label>
                                    <input type="text" class="form-control" id="orderNumber" name="orderNumber"
                                           placeholder="VD: FRUIT2024001">
                                </div>
                            </div>

                            <!-- Loại yêu cầu -->
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <h4 class="mb-4"><i class="fas fa-tags me-2 text-success"></i>Loại yêu cầu</h4>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label for="requestType" class="form-label">
                                        Phân loại yêu cầu <span class="text-danger">*</span>
                                    </label>
                                    <select class="form-select" id="requestType" name="requestType" required>
                                        <option value="" selected disabled>-- Chọn loại yêu cầu --</option>
                                        <option value="order">Hỗ trợ đơn hàng</option>
                                        <option value="delivery">Vấn đề giao hàng</option>
                                        <option value="product">Chất lượng sản phẩm</option>
                                        <option value="payment">Thanh toán & Hoàn tiền</option>
                                        <option value="account">Tài khoản người dùng</option>
                                        <option value="technical">Kỹ thuật & Website</option>
                                        <option value="feedback">Góp ý & Phản hồi</option>
                                        <option value="other">Yêu cầu khác</option>
                                    </select>
                                    <div class="invalid-feedback">
                                        Vui lòng chọn loại yêu cầu
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="priority" class="form-label">
                                        Mức độ ưu tiên <span class="text-danger">*</span>
                                    </label>
                                    <select class="form-select" id="priority" name="priority" required>
                                        <option value="low" selected>Thấp</option>
                                        <option value="medium">Trung bình</option>
                                        <option value="high">Cao</option>
                                        <option value="urgent">Khẩn cấp <span class="urgent">!</span></option>
                                    </select>
                                    <div class="form-text">
                                        <span id="priorityText" class="priority-low priority-badge">Phản hồi trong 48h</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Nội dung chi tiết -->
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <h4 class="mb-4"><i class="fas fa-file-alt me-2 text-info"></i>Nội dung chi tiết</h4>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="subject" class="form-label">
                                    Tiêu đề yêu cầu <span class="text-danger">*</span>
                                </label>
                                <input type="text" class="form-control" id="subject" name="subject"
                                       placeholder="Mô tả ngắn gọn yêu cầu của bạn" required>
                                <div class="invalid-feedback">
                                    Vui lòng nhập tiêu đề yêu cầu
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="description" class="form-label">
                                    Mô tả chi tiết <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control" id="description" name="description"
                                          rows="6" placeholder="Mô tả chi tiết vấn đề của bạn..." required></textarea>
                                <div class="form-text">
                                    Vui lòng mô tả càng chi tiết càng tốt để chúng tôi có thể hỗ trợ bạn nhanh chóng
                                </div>
                                <div class="invalid-feedback">
                                    Vui lòng mô tả chi tiết yêu cầu của bạn
                                </div>
                            </div>

                            <!-- File đính kèm -->
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <h4 class="mb-4"><i class="fas fa-paperclip me-2 text-warning"></i>File đính kèm</h4>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div id="fileUploadArea" class="file-upload-area">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <h5>Kéo thả file hoặc click để chọn</h5>
                                    <p class="text-muted">Hỗ trợ: JPG, PNG, PDF, DOC, DOCX (Tối đa 5MB/file)</p>
                                    <input type="file" id="fileInput" multiple accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                                           style="display: none;">
                                </div>
                                <div id="selectedFiles" class="selected-files"></div>
                                <div class="form-text">
                                    Bạn có thể đính kèm tối đa 5 file. Tổng dung lượng không quá 20MB.
                                </div>
                            </div>

                            <!-- Thông tin liên hệ bổ sung -->
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <h4 class="mb-4"><i class="fas fa-comments me-2 text-purple"></i>Phương thức liên hệ</h4>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-label">Bạn muốn được liên hệ qua:</div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" id="contactPhone" name="contactMethod" value="phone" checked>
                                    <label class="form-check-label" for="contactPhone">Điện thoại</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" id="contactEmail" name="contactMethod" value="email" checked>
                                    <label class="form-check-label" for="contactEmail">Email</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" id="contactSMS" name="contactMethod" value="sms">
                                    <label class="form-check-label" for="contactSMS">SMS</label>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="agreeTerms" name="agreeTerms" required>
                                    <label class="form-check-label" for="agreeTerms">
                                        Tôi đồng ý với <a href="#" class="text-primary">Chính sách bảo mật</a> và
                                        <a href="#" class="text-primary">Điều khoản dịch vụ</a> của Fruit-Store
                                        <span class="text-danger">*</span>
                                    </label>
                                    <div class="invalid-feedback">
                                        Bạn cần đồng ý với điều khoản để gửi yêu cầu
                                    </div>
                                </div>
                            </div>

                            <!-- Thông tin xử lý -->
                            <div class="processing-info">
                                <h5><i class="fas fa-info-circle me-2"></i>Thông tin xử lý yêu cầu</h5>
                                <ul class="mb-0">
                                    <li>Yêu cầu của bạn sẽ được tiếp nhận và xử lý trong vòng 24 giờ làm việc</li>
                                    <li>Đối với yêu cầu khẩn cấp, vui lòng gọi hotline: <strong>1900 1234</strong></li>
                                    <li>Bạn sẽ nhận được email xác nhận khi yêu cầu được tiếp nhận</li>
                                    <li>Bạn có thể theo dõi trạng thái yêu cầu trong mục "Hỗ trợ" của tài khoản</li>
                                </ul>
                            </div>

                            <!-- Nút gửi -->
                            <div class="text-center mt-5">
                                <button type="submit" class="btn btn-submit btn-lg px-5" id="submitBtn">
                                    <i class="fas fa-paper-plane me-2"></i>Gửi Yêu Cầu
                                </button>
                                <div class="mt-3">
                                    <a href="@Url.Action("Index", "HoTroKH")" class="back-link">
                                        <i class="fas fa-arrow-left me-2"></i>Quay lại trang hỗ trợ
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal Success -->
<div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-check-circle me-2"></i>Thành công!</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                <h4>Yêu cầu đã được gửi thành công!</h4>
                <p class="text-muted">Chúng tôi sẽ liên hệ lại với bạn trong thời gian sớm nhất.</p>
                <div class="mt-4">
                    <p><strong>Mã yêu cầu:</strong> <span id="requestCode" class="text-primary">SUPPORT-@(DateTime.Now.ToString("yyyyMMddHHmmss"))</span></p>
                    <p><small>Vui lòng lưu mã này để theo dõi trạng thái yêu cầu</small></p>
                </div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <a href="@Url.Action("Index", "HoTroKH")" class="btn btn-success">Về trang hỗ trợ</a>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Elements
            const form = document.getElementById('supportRequestForm');
            const fileUploadArea = document.getElementById('fileUploadArea');
            const fileInput = document.getElementById('fileInput');
            const selectedFilesDiv = document.getElementById('selectedFiles');
            const submitBtn = document.getElementById('submitBtn');
            const prioritySelect = document.getElementById('priority');
            const priorityText = document.getElementById('priorityText');
            const successModal = new bootstrap.Modal(document.getElementById('successModal'));

            let files = [];
            const maxFiles = 5;
            const maxFileSize = 5 * 1024 * 1024; // 5MB
            const maxTotalSize = 20 * 1024 * 1024; // 20MB

            // Priority text update
            const priorityMessages = {
                'low': { text: 'Phản hồi trong 48h', class: 'priority-low' },
                'medium': { text: 'Phản hồi trong 24h', class: 'priority-medium' },
                'high': { text: 'Phản hồi trong 12h', class: 'priority-high' },
                'urgent': { text: 'Phản hồi trong 4h', class: 'priority-high' }
            };

            prioritySelect.addEventListener('change', function() {
                const value = this.value;
                const info = priorityMessages[value];
                priorityText.textContent = info.text;
                priorityText.className = `priority-badge ${info.class}`;
            });

            // File upload handling
            fileUploadArea.addEventListener('click', () => fileInput.click());

            fileInput.addEventListener('change', handleFileSelect);

            // Drag and drop
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                fileUploadArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                fileUploadArea.addEventListener(eventName, highlight, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                fileUploadArea.addEventListener(eventName, unhighlight, false);
            });

            function highlight() {
                fileUploadArea.classList.add('drag-over');
            }

            function unhighlight() {
                fileUploadArea.classList.remove('drag-over');
            }

            fileUploadArea.addEventListener('drop', handleDrop, false);

            function handleDrop(e) {
                const dt = e.dataTransfer;
                const droppedFiles = dt.files;
                handleFiles(droppedFiles);
            }

            function handleFileSelect(e) {
                const selectedFiles = e.target.files;
                handleFiles(selectedFiles);
            }

            function handleFiles(fileList) {
                // Check total files limit
                if (files.length + fileList.length > maxFiles) {
                    alert(`Bạn chỉ có thể đính kèm tối đa ${maxFiles} file`);
                    return;
                }

                // Check each file
                for (let i = 0; i < fileList.length; i++) {
                    const file = fileList[i];

                    // Check file size
                    if (file.size > maxFileSize) {
                        alert(`File "${file.name}" vượt quá dung lượng cho phép (5MB)`);
                        continue;
                    }

                    // Check total size
                    const currentTotalSize = files.reduce((sum, f) => sum + f.size, 0);
                    if (currentTotalSize + file.size > maxTotalSize) {
                        alert('Tổng dung lượng file vượt quá 20MB');
                        break;
                    }

                    // Check file type
                    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf',
                                          'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
                    if (!allowedTypes.includes(file.type)) {
                        alert(`File "${file.name}" có định dạng không được hỗ trợ`);
                        continue;
                    }

                    files.push(file);
                }

                updateFileList();
            }

            function updateFileList() {
                selectedFilesDiv.innerHTML = '';

                files.forEach((file, index) => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'file-item';

                    const fileInfo = document.createElement('div');
                    fileInfo.innerHTML = `
                        <i class="fas fa-file me-2"></i>
                        <span>${file.name}</span>
                        <small class="text-muted ms-2">(${formatFileSize(file.size)})</small>
                    `;

                    const deleteBtn = document.createElement('i');
                    deleteBtn.className = 'fas fa-times';
                    deleteBtn.title = 'Xóa file';
                    deleteBtn.onclick = () => removeFile(index);

                    fileItem.appendChild(fileInfo);
                    fileItem.appendChild(deleteBtn);
                    selectedFilesDiv.appendChild(fileItem);
                });
            }

            function removeFile(index) {
                files.splice(index, 1);
                updateFileList();
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            // Form validation and submission
            form.addEventListener('submit', function(e) {
                e.preventDefault();

                if (!form.checkValidity()) {
                    e.stopPropagation();
                    form.classList.add('was-validated');
                    return;
                }

                // Disable submit button and show loading
                submitBtn.disabled = true;
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';

                // Simulate API call (replace with actual AJAX call)
                setTimeout(() => {
                    // Get form data
                    const formData = {
                        fullName: document.getElementById('fullName').value,
                        phoneNumber: document.getElementById('phoneNumber').value,
                        email: document.getElementById('email').value,
                        orderNumber: document.getElementById('orderNumber').value,
                        requestType: document.getElementById('requestType').value,
                        priority: document.getElementById('priority').value,
                        subject: document.getElementById('subject').value,
                        description: document.getElementById('description').value,
                        contactMethods: Array.from(document.querySelectorAll('input[name="contactMethod"]:checked'))
                                           .map(cb => cb.value),
                        files: files.length,
                        timestamp: new Date().toISOString()
                    };

                    // In production, send this to your API
                    console.log('Form data:', formData);
                    console.log('Files:', files);

                    // Show success modal
                    successModal.show();

                    // Reset form
                    form.reset();
                    form.classList.remove('was-validated');
                    files = [];
                    updateFileList();

                    // Reset button
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;

                    // Generate request code
                    const requestCode = `FRUIT-SUPPORT-${Date.now().toString().slice(-8)}`;
                    document.getElementById('requestCode').textContent = requestCode;

                }, 1500);
            });

            // Real-time validation
            const inputs = form.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                input.addEventListener('blur', function() {
                    if (this.checkValidity) {
                        this.classList.remove('is-invalid');
                        if (!this.checkValidity()) {
                            this.classList.add('is-invalid');
                        }
                    }
                });
            });

            // Initialize priority text
            prioritySelect.dispatchEvent(new Event('change'));
        });
    </script>
}