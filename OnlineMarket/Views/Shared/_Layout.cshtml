@using OnlineMarket.Models
@using System.Linq

@{
    // 1. Khởi tạo biến đếm bằng 0
    int totalQuantity = 0;

    // 2. Kiểm tra nếu người dùng đã đăng nhập (Có Session UserID)
    if (Session["UserID"] != null)
    {
        try
        {
            // Lấy UserID từ Session
            int userId = Convert.ToInt32(Session["UserID"]);

            // 3. Kết nối Database để đếm số lượng trong bảng GioHang
            using (var db = new QL_OnlineMarketEntities())
            {
                // Tính tổng cột SOLUONG của user đó
                var sum = db.GioHangs
                            .Where(g => g.MAND == userId)
                            .Sum(g => (int?)g.SOLUONG); // Dùng int? để tránh lỗi nếu null

                totalQuantity = sum ?? 0; // Nếu null thì bằng 0
            }
        }
        catch
        {
            // Nếu có lỗi kết nối thì cứ để là 0
            totalQuantity = 0;
        }
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fruit-Store</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="@Url.Content("~/Content/css/style.css")">
</head>
<body>
    <section id="header">
        <a href="@Url.Action("Index", "Home")"><img src="@Url.Content("~/Content/img/logo.jpg")" class="logo" alt="Logo"></a>

        <div>
            <ul id="navbar">
                <li><a class="@(ViewContext.RouteData.Values["Action"].ToString() == "Index" && ViewContext.RouteData.Values["Controller"].ToString() == "Home" ? "active" : "")" href="@Url.Action("Index", "Home")">Home</a></li>
                <li><a href="@Url.Action("Index", "Shop")">Shop</a></li>
                <li><a href="@Url.Action("Index", "Blog")">Blog</a></li>
                <li><a href="@Url.Action("About", "Home")">About</a></li>
                <li><a href="@Url.Action("Contact", "Home")">Contact</a></li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-user"></i>
                        @if (Session["UserName"] != null)
                        {
                        <span>@Session["UserName"]</span>
                        }
                        else if (Request.IsAuthenticated)
                        {
                        <span>@User.Identity.Name</span>
                        }
                        else
                        {
                        <span>Tài khoản</span>
                        }
                    </a>

                    <ul class="dropdown-menu" aria-labelledby="userDropdown">
                        @if (Session["UserName"] != null || Request.IsAuthenticated)
                        {
                            <li>
                                <div class="dropdown-header">
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar me-2">
                                            <i class="fa-solid fa-user-circle fa-lg text-primary"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@(Session["UserName"] ?? User.Identity.Name)</h6>

                                            <small class="text-muted">
                                                @(Session["UserRole"] != null ? Session["UserRole"].ToString() : "Thành viên")
                                            </small>
                                            <small>
                                                <a class="dropdown-item" href="@Url.Action("Index", "HoTroKH")">
                                                    <i class="fas fa-headset me-2 text-info"></i> Hỗ trợ khách hàng
                                                </a>
                                            </small>
                                           
                                        </div>
                                        
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>

                            /* --- LOGIC HIỂN THỊ RIÊNG CHO ADMIN --- */
                            if (Session["UserRole"] != null && (Session["UserRole"].ToString() == "Admin" || Session["UserRole"].ToString() == "Quản trị viên"))
                            {
                                <li>
                                    <a class="dropdown-item fw-bold text-danger" href="@Url.Action("Dashboard", "Account")">
                                        <i class="fas fa-tachometer-alt me-2"></i> Vào trang quản trị
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                            }
                            /* -------------------------------------- */


                            if (Session["UserRole"] != null && (Session["UserRole"].ToString() == "User" || Session["UserRole"].ToString() == "Customer"))
                            {
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index", "HoTroKH")">
                                        <i class="fas fa-headset me-2 text-info"></i> Hỗ trợ khách hàng
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                            }

                            <li>
                                <a class="dropdown-item" href="@Url.Action("Logout", "Account")">
                                    <i class="fa-solid fa-right-from-bracket me-2 text-danger"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li>
                                <div class="dropdown-header">
                                    <i class="fas fa-user-secret me-2"></i>
                                    <span>Khách vãng lai</span>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" href="@Url.Action("Login", "Account")">
                                    <i class="fa-solid fa-sign-in-alt me-2 text-success"></i> Đăng nhập
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Register", "Account")">
                                    <i class="fa-solid fa-user-plus me-2 text-primary"></i> Đăng ký
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("LoginAM", "Account")">
                                    <i class="fa-solid fa-user-shield me-2 text-dark"></i> Quản trị viên
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Index", "HoTroKH")">
                                    <i class="fas fa-headset me-2 text-info"></i> Hỗ trợ khách hàng
                                </a>
                            </li>

                        }
                    </ul>
                </li>

                <li id="lg-bag">
                    <a href="@Url.Action("Index", "Cart")">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <span id="cart-count" class="badge bg-danger">@totalQuantity</span>
                    </a>
                </li>
                <a href="#" id="close"><i class="fa-solid fa-xmark"></i></a>
            </ul>
        </div>

        <div id="mobile">
            <a href="@Url.Action("Index", "Cart")">
                <i class="fa-solid fa-cart-shopping"></i>
            </a>
            <i id="bar" class="fas fa-outdent"></i>
        </div>
    </section>

    <main>
        @Html.Partial("_ChatboxPartial")
        @RenderBody()
    </main>

    <footer id="section-p1">
        <div class="col">
            <img class="logo" src="@Url.Content("~/Content/img/logo.jpg")" alt="Footer Logo">
            <h4>Thông Tin Liên Hệ</h4>
            <p><strong>Địa chỉ: </strong>VietNam, HCM city, Quan Binh Tan</p>
            <p><strong>Số điện thoại: </strong>+326371255 (84+)</p>
            <p><strong>Giờ: </strong>09:00 - 18:00</p>
            <div class="follow">
                <h4>Theo chúng tôi</h4>
                <div class="icon">
                    <i class="fab fa-facebook"></i>
                    <i class="fab fa-tiktok"></i>
                    <i class="fab fa-instagram"></i>
                </div>
            </div>
        </div>

        <div class="col">
            <h4>Liên Hệ</h4>
            <a href="@Url.Action("About", "Home")">Về chúng tôi</a>
            <a href="#">Thông tin giao hàng</a>
            <a href="#">Chính sách bảo mật</a>
            <a href="#">Điều khoản & Điều kiện</a>
            <a href="@Url.Action("Contact", "Home")">Liên hệ chúng tôi</a>
        </div>

       

        <div class="col install">
            <h4>Tải Ứng Dụng</h4>
            <p>Từ App Store hay Ch Play</p>
            <div class="row">
                <img src="@Url.Content("~/Content/img/pay/app.jpg")" alt="App Store">
                <img src="@Url.Content("~/Content/img/pay/play.jpg")" alt="Google Play">
            </div>
            <p>Cổng thanh toán</p>
            <img src="@Url.Content("~/Content/img/pay/pay.png")" alt="Payment Methods">
        </div>

        <div class="copyright">
            <p>© SangT2, LapTrinhWeb</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    <script src="@Url.Content("~/Scripts/script.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
