@{
    ViewBag.Title = "Thêm Danh mục mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Thêm Danh mục mới</h1>
        <a href="@Url.Action("Categories")" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Danh mục</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("CategoryCreate", "Account", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="TENDM">Tên Danh mục *</label>
                    <input type="text" class="form-control" id="TENDM" name="TENDM"
                           required placeholder="Nhập tên danh mục" maxlength="100">
                    <small class="form-text text-muted">Tên danh mục không được trùng với danh mục đã có.</small>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu Danh mục
                    </button>
                    <a href="@Url.Action("Categories")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            }
        </div>
    </div>
</div>