@model DanhMuc
@{
    ViewBag.Title = "Chỉnh sửa Danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chỉnh sửa Danh mục</h1>
        <a href="@Url.Action("Categories")" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Chỉnh sửa Danh mục: @Model.TENDM</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("CategoryEdit", "Account", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="MADM" value="@Model.MADM" />

                <div class="form-group">
                    <label for="TENDM">Tên Danh mục *</label>
                    <input type="text" class="form-control" id="TENDM" name="TENDM"
                           required value="@Model.TENDM" placeholder="Nhập tên danh mục" maxlength="100">
                    <small class="form-text text-muted">Tên danh mục không được trùng với danh mục đã có.</small>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                    <a href="@Url.Action("Categories")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Thông tin thêm -->
    <div class="row">
        <div class="col-md-12">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Thông tin
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-gray-800">
                                <i class="fas fa-info-circle"></i>
                                Danh mục này hiện có @Model.SanPhams.Count(p => p.MADM == Model.MADM) sản phẩm.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>