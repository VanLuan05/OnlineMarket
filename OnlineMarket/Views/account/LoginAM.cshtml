@{
    ViewBag.Title = "Đăng Nhập Hệ Thống Quản Trị";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Fruit Store</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #05a569;
            --primary-hover: #048a57;
            --text-main: #111827;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --bg-input: #f9fafb;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #fff;
            color: var(--text-main);
            overflow-x: hidden;
        }

        /* ----- Layout Chia Đôi Màn Hình ----- */
        .split-layout {
            display: flex;
            min-height: 100vh;
        }

        /* Phần ảnh bên trái */
        .split-image {
            flex: 1.2;
            position: relative;
            /* Đã sử dụng ảnh hero.jpg có sẵn trong project của bạn */
            background: url('@Url.Content("~/Content/img/bg-ad.jpg")') center center / cover no-repeat;
            display: none;
        }
        @@media (min-width: 992px) {
            .split-image {
                display: block;
            }
        }

        /* Lớp phủ màu xanh đen sang trọng lên ảnh */
        .image-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(3, 37, 25, 0.85) 0%, rgba(5, 165, 105, 0.7) 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            color: #fff;
        }

        .image-overlay h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .image-overlay p {
            font-size: 1.1rem;
            font-weight: 300;
            opacity: 0.9;
            max-width: 500px;
            line-height: 1.6;
        }

        /* Phần Form bên phải */
        .split-form {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 2rem 3rem;
            background-color: #fff;
            max-width: 600px;
            margin: 0 auto;
        }

        .form-header {
            margin-bottom: 2.5rem;
        }

        .form-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Tùy chỉnh ô nhập liệu Minimalist */
        .form-label {
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: #374151;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .form-control {
            height: 50px;
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0 1rem 0 3rem;
            font-size: 0.95rem;
            color: var(--text-main);
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background-color: #fff;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(5, 165, 105, 0.1);
        }

        .input-icon {
            position: absolute;
            top: 50%;
            left: 1rem;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 1.1rem;
            z-index: 5;
            transition: color 0.2s;
        }

        .form-control:focus ~ .input-icon {
            color: var(--primary);
        }

        .btn-toggle-pass {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            background: transparent;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            z-index: 5;
        }
        .btn-toggle-pass:hover {
            color: var(--text-main);
        }

        /* Nút đăng nhập */
        .btn-submit {
            height: 50px;
            width: 100%;
            background-color: var(--primary);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            margin-top: 1rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-submit:hover {
            background-color: var(--primary-hover);
        }

        .btn-submit:disabled {
            background-color: #9ca3af;
            cursor: not-allowed;
        }

        /* Liên kết & Checkbox */
        .form-check-input {
            cursor: pointer;
        }
        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }
        .form-check-label {
            font-size: 0.9rem;
            color: var(--text-muted);
            cursor: pointer;
        }

        .text-link {
            font-size: 0.9rem;
            color: var(--primary);
            font-weight: 500;
            text-decoration: none;
        }
        .text-link:hover {
            text-decoration: underline;
        }

        /* Alert Box */
        .alert-custom {
            border-radius: 8px;
            font-size: 0.9rem;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            border: none;
        }
        .alert-error {
            background-color: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }
        .alert-success {
            background-color: #ecfdf5;
            color: #047857;
            border: 1px solid #a7f3d0;
        }

        .back-link {
            display: inline-block;
            margin-top: 2rem;
            font-size: 0.9rem;
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s;
        }
        .back-link:hover {
            color: var(--primary);
        }
    </style>
</head>
<body>

    <div class="split-layout">
        <div class="split-image">
            <div class="image-overlay">
                <div>
                    <h1>OnlineMarket<br>Workspace</h1>
                    <p>Hệ thống quản lý nội bộ dành riêng cho đội ngũ vận hành Fruit Store. Giám sát đơn hàng, cập nhật sản phẩm và theo dõi doanh thu theo thời gian thực.</p>
                </div>
            </div>
        </div>

        <div class="split-form">
            <div class="w-100">
                <div class="form-header">
                    <h2>Đăng nhập</h2>
                    <p>Vui lòng điền thông tin tài khoản quản trị để tiếp tục.</p>
                </div>

                <form id="adminLoginForm">
                    <label class="form-label">Tài khoản quản trị</label>
                    <div class="input-group-custom">
                        <input type="text" class="form-control" id="username" name="username" required autocomplete="username">
                        <i class="fas fa-user input-icon"></i>
                    </div>

                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group-custom">
                        <input type="password" class="form-control" id="password" name="password" required autocomplete="current-password">
                        <i class="fas fa-lock input-icon"></i>
                        <button type="button" class="btn-toggle-pass" id="btnTogglePass">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Lưu đăng nhập
                            </label>
                        </div>
                        <a href="#" class="text-link">Quên mật khẩu?</a>
                    </div>

                    <div id="messageBox" class="mb-2"></div>

                    <button type="submit" class="btn-submit" id="btnSubmit">
                        <span id="btnText">Đăng nhập</span>
                        <span id="btnLoading" class="spinner-border spinner-border-sm d-none" role="status"></span>
                    </button>
                </form>

                <div class="text-center">
                    <a href="@Url.Action("Index", "Home")" class="back-link">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại cửa hàng
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {
            // Xử lý bật/tắt hiển thị mật khẩu
            $('#btnTogglePass').click(function () {
                const passInput = $('#password');
                const icon = $(this).find('i');

                if (passInput.attr('type') === 'password') {
                    passInput.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    passInput.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Xử lý logic AJAX gửi form (Đảm bảo biến khớp 100% với Controller)
            $('#adminLoginForm').submit(function (e) {
                e.preventDefault();

                // Lấy dữ liệu
                const username = $('#username').val().trim();
                const password = $('#password').val().trim();
                const rememberMe = $('#rememberMe').is(':checked');

                // Xóa thông báo cũ
                $('#messageBox').empty();

                // Kiểm tra rỗng
                if (!username || !password) {
                    showMessage('Vui lòng nhập đầy đủ thông tin.', 'error');
                    return;
                }

                // Trạng thái Loading cho Nút bấm
                $('#btnText').text('Đang xác thực...');
                $('#btnLoading').removeClass('d-none');
                $('#btnSubmit').prop('disabled', true);

                // Gửi dữ liệu tới hàm LoginAM trong AccountController.cs
                $.ajax({
                    url: '@Url.Action("LoginAM", "Account")',
                    type: 'POST',
                    data: {
                        username: username,
                        password: password,
                        rememberMe: rememberMe
                    },
                    success: function (response) {
                        if (response.success) {
                            // Thành công
                            showMessage(response.message, 'success');

                            // Chuyển hướng sang trang Dashboard sau 1 giây
                            setTimeout(() => {
                                window.location.href = '@Url.Action("Dashboard", "Account")';
                            }, 1000);
                        } else {
                            // Thất bại
                            showMessage(response.message, 'error');
                            resetButton();
                        }
                    },
                    error: function () {
                        // Lỗi kết nối
                        showMessage('Không thể kết nối đến máy chủ. Vui lòng thử lại!', 'error');
                        resetButton();
                    }
                });
            });

            // Hàm hiển thị thông báo
            function showMessage(text, type) {
                const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
                const cssClass = type === 'success' ? 'alert-success' : 'alert-error';

                $('#messageBox').html(`
                    <div class="alert-custom ${cssClass}">
                        <i class="fas ${icon}"></i>
                        <span>${text}</span>
                    </div>
                `);
            }

            // Hàm khôi phục nút bấm
            function resetButton() {
                $('#btnText').text('Đăng nhập');
                $('#btnLoading').addClass('d-none');
                $('#btnSubmit').prop('disabled', false);
            }
        });
    </script>
</body>
</html>