@model CustomerDetailViewModel
@{
    ViewBag.Title = "Chi tiết Khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var customer = Model.Customer;
    var stats = Model.OrderStats;
    var loyaltyPoints = ViewBag.LoyaltyPoints ?? 0;
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-user mr-2"></i>Chi tiết Khách hàng
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Customers", "Account")">Khách hàng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@customer.HOTEN</li>
                </ol>
            </nav>
        </div>
        <div class="btn-group" role="group">
            <a href="@Url.Action("CustomerEdit", new { id = customer.MAND })" class="btn btn-warning">
                <i class="fas fa-edit mr-1"></i> Chỉnh sửa
            </a>
            <a href="@Url.Action("ExportCustomerData", new { id = customer.MAND })" class="btn btn-info ml-2">
                <i class="fas fa-download mr-1"></i> Xuất dữ liệu
            </a>
            <a href="@Url.Action("Customers", "Account")" class="btn btn-secondary ml-2">
                <i class="fas fa-arrow-left mr-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Left Column: Customer Info & Stats -->
        <div class="col-lg-4">
            <!-- Customer Info Card -->
            <div class="card shadow mb-4 border-left-primary">
                <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-user-circle mr-1"></i>Thông tin cá nhân
                    </h6>
                    <span class="badge @(customer.VAITRO == "Account" ? "badge-danger" : "badge-primary")">
                        @customer.VAITRO
                    </span>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-3"
                             style="width: 100px; height: 100px;">
                            <i class="fas fa-user fa-3x text-white"></i>
                        </div>
                        <h4 class="font-weight-bold">@customer.HOTEN</h4>
                        <p class="text-muted">Mã KH: #@customer.MAND</p>
                        <p class="text-muted">
                            <code>@customer.TENDANGNHAP</code>
                        </p>
                    </div>

                    <table class="table table-borderless">
                        <tr>
                            <td width="40%"><i class="fas fa-envelope text-primary mr-2"></i> Email:</td>
                            <td><strong>@customer.EMAIL</strong></td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-phone text-primary mr-2"></i> SĐT:</td>
                            <td>@customer.SODIENTHOAI</td>
                        </tr>
                        <tr>
                            <td><i class="fas fa-map-marker-alt text-primary mr-2"></i> Địa chỉ:</td>
                            <td>@customer.DIACHI</td>
                        </tr>
                        <tr>
                            <td colspan="2" class="pt-3">
                                <a href="@Url.Action("CustomerAddresses", new { id = customer.MAND })" class="btn btn-outline-primary btn-sm btn-block">
                                    <i class="fas fa-address-book mr-1"></i> Xem địa chỉ giao hàng
                                    @if (Model.ShippingAddresses != null && Model.ShippingAddresses.Any())
                                    {
                                        <span class="badge badge-primary ml-1">@Model.ShippingAddresses.Count</span>
                                    }
                                </a>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Order Statistics Card -->
            <div class="card shadow mb-4 border-left-success">
                <div class="card-header py-3 bg-white">
                    <h6 class="m-0 font-weight-bold text-success">
                        <i class="fas fa-chart-bar mr-1"></i>Thống kê đơn hàng
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 mb-3">
                            <div class="text-xs font-weight-bold text-primary text-uppercase">Tổng đơn</div>
                            <div class="h4 font-weight-bold">@stats.TotalOrders</div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-xs font-weight-bold text-success text-uppercase">Hoàn thành</div>
                            <div class="h4 font-weight-bold">@stats.CompletedOrders</div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-xs font-weight-bold text-warning text-uppercase">Đang xử lý</div>
                            <div class="h4 font-weight-bold">@stats.PendingOrders</div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="text-xs font-weight-bold text-danger text-uppercase">Đã hủy</div>
                            <div class="h4 font-weight-bold">@stats.CancelledOrders</div>
                        </div>
                    </div>

                    <hr>

                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Tổng chi tiêu:</span>
                            <span class="font-weight-bold text-success">@stats.TotalSpent.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Giá trị đơn TB:</span>
                            <span class="font-weight-bold">@stats.AverageOrderValue.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Điểm tích lũy:</span>
                            <span class="font-weight-bold text-warning">@loyaltyPoints điểm</span>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="@Url.Action("CustomerOrders", new { id = customer.MAND })" class="btn btn-success btn-block">
                            <i class="fas fa-shopping-cart mr-1"></i> Xem tất cả đơn hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Recent Orders & Reviews -->
        <div class="col-lg-8">
            <!-- Recent Orders Card -->
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-receipt mr-1"></i>Đơn hàng gần đây
                    </h6>
                    <a href="@Url.Action("CustomerOrders", new { id = customer.MAND })" class="btn btn-sm btn-primary">
                        Xem tất cả
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.RecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless">
                                <thead>
                                    <tr class="border-bottom">
                                        <th>Mã đơn</th>
                                        <th>Ngày đặt</th>
                                        <th>Tổng tiền</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        var statusClass = "bg-secondary";
                                        if (order.TRANG_THAI == "Chờ xác nhận") { statusClass = "bg-warning"; }
                                        else if (order.TRANG_THAI == "Đã xác nhận") { statusClass = "bg-info"; }
                                        else if (order.TRANG_THAI == "Đang giao") { statusClass = "bg-primary"; }
                                        else if (order.TRANG_THAI == "Hoàn thành") { statusClass = "bg-success"; }
                                        else if (order.TRANG_THAI == "Đã hủy") { statusClass = "bg-danger"; }

                                        <tr class="border-bottom">
                                            <td>#@order.MADH</td>
                                            <td>@order.NGAYDAT.ToString()</td>
                                            <td class="text-success font-weight-bold">@order.TongThanhToan.ToString()đ</td>
                                            <td>
                                                <span class="badge @statusClass">@order.TRANG_THAI</span>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="@Url.Action("OrderDetails", new { id = order.MADH })"
                                                       class="btn btn-info" title="Chi tiết">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Quick Stats -->
                        <div class="row mt-3">
                            <div class="col-md-4">
                                <div class="card border-left-primary shadow-sm">
                                    <div class="card-body py-2">
                                        <div class="text-xs font-weight-bold text-primary text-uppercase">Tổng đơn 30 ngày</div>
                                        <div class="h6 mb-0 font-weight-bold">
                                            @{
                                                var last30DaysOrders = Model.RecentOrders
                                                    .Count(o => o.NGAYDAT.HasValue && o.NGAYDAT.Value >= DateTime.Now.AddDays(-30));
                                            }
                                            @last30DaysOrders đơn
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-left-success shadow-sm">
                                    <div class="card-body py-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase">Chi tiêu 30 ngày</div>
                                        <div class="h6 mb-0 font-weight-bold text-success">
                                            @{
                                                var last30DaysSpent = Model.RecentOrders
                                                    .Where(o => o.NGAYDAT.HasValue && o.NGAYDAT.Value >= DateTime.Now.AddDays(-30) && o.TRANG_THAI == "Hoàn thành")
                                                    .Sum(o => o.TongThanhToan) ?? 0;
                                            }
                                            @last30DaysSpent.ToString("N0")đ
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-left-warning shadow-sm">
                                    <div class="card-body py-2">
                                        <div class="text-xs font-weight-bold text-warning text-uppercase">Tỷ lệ hoàn thành</div>
                                        <div class="h6 mb-0 font-weight-bold">
                                            @{
                                                var completionRate = stats.TotalOrders > 0 ?
                                                    (stats.CompletedOrders * 100 / stats.TotalOrders) : 0;
                                            }
                                            @completionRate%
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-shopping-cart fa-2x text-gray-300 mb-3"></i>
                            <h6 class="text-gray-500">Chưa có đơn hàng nào</h6>
                            <p class="text-muted">Khách hàng này chưa thực hiện đơn hàng nào</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Customer Reviews Card -->
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-star mr-1"></i>Đánh giá gần đây
                    </h6>
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        <a href="@Url.Action("CustomerReviews", new { id = customer.MAND })" class="btn btn-sm btn-primary">
                            Xem tất cả
                        </a>
                    }
                </div>
                <div class="card-body">
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        <div class="list-group">
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="list-group-item list-group-item-action border-0">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@review.SanPham?.TENSP</h6>
                                        <small class="text-muted">@review.NGAYDANHGIA?.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="mb-1">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= (review.SOSAO ?? 0))
                                            {
                                                <i class="fas fa-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star text-warning"></i>
                                            }
                                        }
                                        <span class="ml-2">@review.SOSAO/5</span>
                                    </div>
                                    <p class="mb-1">@review.NOIDUNG</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-star fa-2x text-gray-300 mb-3"></i>
                            <h6 class="text-gray-500">Chưa có đánh giá nào</h6>
                            <p class="text-muted">Khách hàng này chưa đánh giá sản phẩm nào</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Actions Card -->
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-bolt mr-1"></i>Thao tác nhanh
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <a href="@Url.Action("CustomerOrders", new { id = customer.MAND, status = "Chờ xác nhận" })"
                               class="btn btn-outline-warning btn-block">
                                <i class="fas fa-clock mr-1"></i> Đơn chờ xác nhận
                                @if (stats.PendingOrders > 0)
                                {
                                    <span class="badge badge-warning ml-1">@stats.PendingOrders</span>
                                }
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <a href="@Url.Action("CustomerOrders", new { id = customer.MAND, status = "Đang giao" })"
                               class="btn btn-outline-primary btn-block">
                                <i class="fas fa-truck mr-1"></i> Đơn đang giao
                                @{
                                    var deliveringOrders = Model.RecentOrders.Count(o => o.TRANG_THAI == "Đang giao");
                                }
                                @if (deliveringOrders > 0)
                                {
                                    <span class="badge badge-primary ml-1">@deliveringOrders</span>
                                }
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <a href="@Url.Action("CustomerReviews", new { id = customer.MAND })"
                               class="btn btn-outline-info btn-block">
                                <i class="fas fa-comments mr-1"></i> Đánh giá
                                @if (Model.Reviews != null)
                                {
                                    <span class="badge badge-info ml-1">@Model.Reviews.Count</span>
                                }
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <a href="@Url.Action("CustomerAddresses", new { id = customer.MAND })"
                               class="btn btn-outline-secondary btn-block">
                                <i class="fas fa-address-book mr-1"></i> Địa chỉ giao hàng
                                @if (Model.ShippingAddresses != null)
                                {
                                    <span class="badge badge-secondary ml-1">@Model.ShippingAddresses.Count</span>
                                }
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .list-group-item {
        border-left: 4px solid #4e73df;
        margin-bottom: 5px;
    }

        .list-group-item:hover {
            background-color: #f8f9fc;
        }

    .badge {
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
    }

    .card {
        border-radius: 0.5rem;
    }

    .table-borderless td {
        padding: 0.5rem 0;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add any JavaScript functionality here
        });
    </script>
}