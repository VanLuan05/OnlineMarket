@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - Fruit Store</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #ffffff;
            overflow-x: hidden;
        }

        /* === BỐ CỤC CHIA ĐÔI (SPLIT SCREEN) === */
        .login-wrapper {
            min-height: 100vh;
            display: flex;
        }

        /* Cột Trái: Hình ảnh Banner (Ẩn trên điện thoại) */
        .login-image {
            flex: 1.2; /* Tỷ lệ rộng hơn form một chút */
            background: url('/Content/img/viet-quat.jpg') center/cover no-repeat;
            position: relative;
            display: none;
        }

        @@media (min-width: 992px) {
            .login-image {
                display: block;
            }
        }

        /* Phủ một lớp màu tối/xanh lá nhẹ lên ảnh để chữ nổi bật */
        .login-image::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(25, 135, 84, 0.4), rgba(0, 0, 0, 0.7));
        }

        .brand-text {
            position: absolute;
            bottom: 15%;
            left: 10%;
            color: white;
            z-index: 2;
            max-width: 80%;
        }

        /* Cột Phải: Container chứa Form */
        .login-form-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            position: relative;
        }

        .form-wrapper {
            width: 100%;
            max-width: 400px; /* Giới hạn độ rộng form cho đẹp */
        }

        /* Nút quay lại góc trái form */
        .back-home {
            position: absolute;
            top: 2rem;
            left: 2rem;
            color: #6c757d;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

            .back-home:hover {
                color: #198754;
            }

        /* === STYLING CÁC ELEMENT TRONG FORM === */
        .logo-icon {
            font-size: 3rem;
            color: #198754;
            margin-bottom: 1rem;
            filter: drop-shadow(0 4px 6px rgba(25, 135, 84, 0.2));
        }

        /* Floating Labels Bootstrap custom */
        .form-floating > .form-control:focus ~ label,
        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: #198754;
            font-weight: 600;
        }

        .form-control {
            border: 2px solid #edf2f7;
            background-color: #fbfbfc;
        }

            .form-control:focus {
                border-color: #198754;
                box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15);
                background-color: #ffffff;
            }

        .btn-login {
            background-color: #198754;
            color: white;
            border-radius: 50px;
            padding: 14px;
            font-weight: 700;
            letter-spacing: 0.5px;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                background-color: #157347;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(25, 135, 84, 0.3);
            }

        /* Dòng chữ "Hoặc" */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 2rem 0;
            color: #adb5bd;
            font-size: 0.9rem;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #edf2f7;
            }

            .divider:not(:empty)::before {
                margin-right: 1em;
            }

            .divider:not(:empty)::after {
                margin-left: 1em;
            }
    </style>
</head>
<body>

    <div class="login-wrapper">

        <div class="login-image shadow-lg">
            <div class="brand-text">
                <h1 class="display-4 fw-bold mb-3 text-white">Online Market</h1>
                <p class="fs-5 text-light text-opacity-75">Nền tảng cung cấp trái cây và thực phẩm tươi sạch, an toàn, giao tận tay gia đình bạn mỗi ngày.</p>
            </div>
        </div>

        <div class="login-form-container">

            <a href="@Url.Action("Index", "Home")" class="back-home">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>

            <div class="form-wrapper">
                <div class="text-center mb-4 mt-5 mt-lg-0">
                    <i class="fas fa-leaf logo-icon"></i>
                    <h2 class="fw-bold text-dark">Đăng Nhập</h2>
                    <p class="text-muted">Chào mừng bạn quay trở lại!</p>
                </div>

                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "needs-validation" }))
                {
                    @Html.AntiForgeryToken()

                    if (ViewData.ModelState.Any(x => x.Value.Errors.Any()))
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-0 text-danger rounded-3 p-3 mb-4 d-flex align-items-center">
                            <i class="fas fa-exclamation-circle fs-5 me-3"></i>
                            <div class="mb-0">@Html.ValidationSummary(true, "")</div>
                        </div>
                    }

                    <div class="form-floating mb-3">
                        <input type="text" name="tendangnhap" class="form-control rounded-4" id="floatingInput" placeholder="Tên đăng nhập" required value="@ViewBag.TenDangNhap">
                        <label for="floatingInput"><i class="fas fa-user text-muted me-2"></i> Tên đăng nhập</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" name="matkhau" class="form-control rounded-4" id="floatingPassword" placeholder="Mật khẩu" required>
                        <label for="floatingPassword"><i class="fas fa-lock text-muted me-2"></i> Mật khẩu</label>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-muted" style="font-size: 0.95rem;" for="rememberMe">Nhớ tài khoản</label>
                        </div>
                        <a href="#" class="text-success text-decoration-none fw-semibold" style="font-size: 0.95rem;">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn btn-login w-100 shadow-sm">
                        ĐĂNG NHẬP
                    </button>
                }

                <div class="divider">HOẶC CHƯA CÓ TÀI KHOẢN?</div>

                <div class="text-center">
                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-success rounded-pill w-100 py-2 fw-bold">
                        Tạo Tài Khoản Mới
                    </a>
                </div>

            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>