@model NguoiDung
@{
    ViewBag.Title = "Chỉnh sửa Người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-user-edit mr-2"></i>Chỉnh sửa Người dùng
        </h1>
        <a href="@Url.Action("CustomerDetails", new { id = Model.MAND })" class="btn btn-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Quay lại
        </a>
    </div>

    <!-- Form Card -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin người dùng</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("CustomerEdit", "Account", FormMethod.Post, new { @class = "form-horizontal" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MAND)

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Tên đăng nhập *</label>
                            @Html.TextBoxFor(m => m.TENDANGNHAP, new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.TENDANGNHAP, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label>Họ tên *</label>
                            @Html.TextBoxFor(m => m.HOTEN, new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.HOTEN, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label>Email *</label>
                            @Html.TextBoxFor(m => m.EMAIL, new { @class = "form-control", type = "email", required = "required" })
                            @Html.ValidationMessageFor(m => m.EMAIL, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Số điện thoại</label>
                            @Html.TextBoxFor(m => m.SODIENTHOAI, new { @class = "form-control" })
                        </div>

                        <div class="form-group">
                            <label>Địa chỉ</label>
                            @Html.TextBoxFor(m => m.DIACHI, new { @class = "form-control" })
                        </div>

                        <div class="form-group">
                            <label>Vai trò</label>
                            @Html.DropDownListFor(m => m.VAITRO,
                                new SelectList(ViewBag.Roles, "Value", "Text", Model.VAITRO),
                                new { @class = "form-control" })
                        </div>

                        <div class="form-group">
                            <label>Mật khẩu mới (để trống nếu không đổi)</label>
                            @Html.PasswordFor(m => m.MATKHAU, new { @class = "form-control", placeholder = "Nhập mật khẩu mới..." })
                            <small class="form-text text-muted">Nếu không muốn thay đổi mật khẩu, hãy để trống trường này.</small>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-1"></i> Lưu thay đổi
                    </button>
                    <a href="@Url.Action("CustomerDetails", new { id = Model.MAND })" class="btn btn-secondary ml-2">
                        <i class="fas fa-times mr-1"></i> Hủy
                    </a>
                </div>
            }
        </div>
    </div>
</div>