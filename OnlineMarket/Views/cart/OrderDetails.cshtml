@model OnlineMarket.DonHang
@{
    ViewBag.Title = "Chi Tiết Đơn Hàng";
    var timeline = ViewBag.Timeline as List<OnlineMarket.Models.TimelineItem>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📋 Chi Tiết Đơn Hàng #@Model.MADH</h2>
        <a href="@Url.Action("OrderHistory", "Cart")" class="btn btn-outline-secondary">
            ↩️ Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Thông tin đơn hàng -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📦 Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Mã đơn hàng:</strong> #@Model.MADH</p>
                            <p><strong>Ngày đặt:</strong> @Model.NGAYDAT.ToString()</p>
                            <p>
                                <strong>Trạng thái:</strong>
                                <span class="badge text-dark @GetStatusBadgeClass(Model.TrangThaiChiTiet)">
                                    @Model.TrangThaiChiTiet
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Tổng tiền hàng:</strong> @(Model.TONGTIEN?.ToString("N0") ?? "0")đ</p>
                            <p><strong>Phí vận chuyển:</strong> @(Model.PhiGiaoHang?.ToString("N0") ?? "0")đ</p>
                            <p>
                                <strong>Tổng thanh toán:</strong>
                                <span class="text-success font-weight-bold">@(Model.TongThanhToan?.ToString("N0") ?? "0")đ</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Danh sách sản phẩm -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">🛍️ Sản phẩm đã đặt</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var chiTiet in Model.ChiTietDonHangs)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@chiTiet.SanPham.URL_ANH" alt="@chiTiet.SanPham.TENSP"
                                                     style="width: 50px; height: 50px; object-fit: cover;" class="mr-3">
                                                <div>
                                                    <strong>@chiTiet.SanPham.TENSP</strong>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@chiTiet.THANHTIEN.ToString()đ</td>
                                        <td>@chiTiet.SOLUONG</td>
                                        <td>@((chiTiet.THANHTIEN * chiTiet.SOLUONG)?.ToString("N0"))đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3" class="text-right"><strong>Tổng cộng:</strong></td>
                                    <td><strong>@(Model.TONGTIEN?.ToString("N0") ?? "0")đ</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Thông tin giao hàng -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">🚚 Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>@Model.HoTenNhanHang</strong><br>
                        📞 @Model.SDTNGUOINHAN
                    </p>
                    <p class="mb-0 text-muted">
                        <strong>Địa chỉ nhận hàng:</strong><br>
                        @Model.DIACHIGIAOHANG<br>
                        @Model.PhuongXa, @Model.QuanHuyen, @Model.TinhThanh
                    </p>
                </div>
            </div>

            <!-- Phương thức thanh toán & giao hàng -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">💳 Phương thức</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Thanh toán:</strong><br>
                        @Model.HinhThucThanhToan
                    </p>
                    <p class="mb-0">
                        <strong>Giao hàng:</strong><br>
                        @Model.PhuongThucGiaoHang
                    </p>
                </div>
            </div>

            <!-- Hỗ trợ -->
            <div class="card">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">📞 Cần hỗ trợ?</h5>
                </div>
                <div class="card-body">
                    <p class="mb-1">Hotline: <strong>1900 1000</strong></p>
                    <p class="mb-1">Email: support@onlinemarket.com</p>
                    <p class="mb-0">Thời gian: 8:00 - 22:00 hàng ngày</p>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetStatusBadgeClass(string status)
    {
        if (status == "Đang xử lý") return "badge-warning";
        if (status == "Đang giao") return "badge-info";
        if (status == "Hoàn tất") return "badge-success";
        if (status == "Hủy") return "badge-danger";
        return "badge-secondary";
    }
}