@model OnlineMarket.DonHang

@{
    ViewBag.Title = "Đặt Hàng Thành Công";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-success">
                <div class="card-body text-center py-5">
                    <!-- Biểu tượng thành công -->
                    <div class="text-success mb-4">
                        <i class="fas fa-check-circle" style="font-size: 5rem;"></i>
                    </div>

                    <h2 class="card-title text-success">🎉 Đặt Hàng Thành Công!</h2>
                    <p class="card-text lead">Cảm ơn bạn đã đặt hàng tại OnlineMarket</p>

                    <!-- Thông tin đơn hàng -->
                    <div class="alert alert-success mt-4">
                        <div class="row text-left">
                            <div class="col-md-6">
                                <p><strong>Mã đơn hàng:</strong> #@Model.MADH</p>
                                <p><strong>Ngày đặt:</strong> @Model.NGAYDAT.ToString()</p>
                                <p><strong>Trạng thái:</strong> <span class="badge badge-warning">@Model.TrangThaiChiTiet</span></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Tổng tiền:</strong> @(Model.TONGTIEN?.ToString("N0") ?? "0")đ</p>
                                <p><strong>Phí vận chuyển:</strong> @(Model.PhiGiaoHang?.ToString("N0") ?? "0")đ</p>
                                <p><strong>Tổng thanh toán:</strong> <span class="text-success font-weight-bold">@(Model.TongThanhToan?.ToString("N0") ?? "0")đ</span></p>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin giao hàng -->
                    <div class="card mt-3">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">🚚 Thông tin giao hàng</h5>
                        </div>
                        <div class="card-body text-left">
                            <p class="mb-1"><strong>@Model.HoTenNhanHang</strong></p>
                            <p class="mb-1">📞 @Model.SDTNGUOINHAN</p>
                            <p class="mb-0 text-muted">
                                @Model.DIACHIGIAOHANG<br>
                                @Model.PhuongXa, @Model.QuanHuyen, @Model.TinhThanh
                            </p>
                        </div>
                    </div>

                    <!-- Timeline đơn giản -->
                    <div class="card mt-3">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">📊 Tiến trình đơn hàng</h5>
                        </div>
                        <div class="card-body">
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     role="progressbar"
                                     style="width: 25%;"
                                     aria-valuenow="25"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    Đang xử lý
                                </div>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted">
                                    Đơn hàng của bạn đã được tiếp nhận và đang được xử lý.
                                    Bạn sẽ nhận được thông báo khi đơn hàng được giao.
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Các nút hành động -->
                    <div class="mt-4">
                        <a href="@Url.Action("Tracking", "Order", new { id = Model.MADH })" class="btn btn-primary btn-lg">
                            📊 Theo dõi đơn hàng
                        </a>
                        <a href="@Url.Action("History", "Order")" class="btn btn-outline-secondary btn-lg">
                            📦 Lịch sử đơn hàng
                        </a>
                        <a href="@Url.Action("Index", "Shop")" class="btn btn-success btn-lg">
                            🛒 Tiếp tục mua sắm
                        </a>
                    </div>

                    <!-- Thông báo quan trọng -->
                    <div class="alert alert-info mt-4">
                        <h6>📌 Lưu ý quan trọng:</h6>
                        <ul class="mb-0 pl-3">
                            <li>Bạn có thể theo dõi trạng thái đơn hàng bất kỳ lúc nào</li>
                            <li>Nhân viên sẽ liên hệ với bạn để xác nhận đơn hàng trong vòng 24h</li>
                            <li>Liên hệ hotline <strong>1900 1000</strong> nếu cần hỗ trợ</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .progress-bar {
        font-weight: bold;
    }

    .card {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }

    .border-success {
        border-width: 2px;
    }
</style>