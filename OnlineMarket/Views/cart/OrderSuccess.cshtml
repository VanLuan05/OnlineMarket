@{
    ViewBag.Title = "Đặt hàng thành công - Fruit Store";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy mã đơn hàng từ tham số URL (orderId) mà hàm PlaceOrder ở JS truyền sang
    var orderId = ViewBag.OrderId ?? Request.QueryString["orderId"] ?? "Đang cập nhật";
}

<style>
    body {
        background-color: #f8f9fc;
    }

    .success-wrapper {
        padding: 60px 0;
        min-height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 50px 40px;
        text-align: center;
        max-width: 600px;
        width: 100%;
        border-top: 6px solid #198754;
    }

    /* Animation cho Icon Success */
    .success-icon-wrap {
        width: 110px;
        height: 110px;
        background: rgba(25, 135, 84, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: pulse 2s infinite;
    }

    .success-icon {
        color: #198754;
        font-size: 4rem;
        animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    @@keyframes scaleIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4);
        }

        70% {
            box-shadow: 0 0 0 20px rgba(25, 135, 84, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    .success-title {
        font-weight: 800;
        color: #2c3e50;
        margin-bottom: 15px;
        font-size: 2.2rem;
    }

    .success-text {
        color: #6c757d;
        font-size: 1.1rem;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    /* Box hiển thị mã đơn hàng */
    .order-code-box {
        background: #f8f9fa;
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 15px 30px;
        margin-bottom: 35px;
        display: inline-block;
        transition: all 0.3s;
    }

        .order-code-box:hover {
            border-color: #198754;
            background: #f0fdf4;
        }

        .order-code-box span {
            color: #8795a1;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .order-code-box h5 {
            margin: 8px 0 0;
            font-weight: 800;
            color: #198754;
            font-size: 1.6rem;
            letter-spacing: 2px;
        }

    /* Nhóm Nút bấm */
    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-track {
        background-color: #198754;
        color: white;
        border-radius: 50px;
        padding: 14px 32px;
        font-weight: 700;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-track:hover {
            background-color: #157347;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(25, 135, 84, 0.3);
            color: white;
        }

    .btn-home {
        background-color: #f1f3f5;
        color: #495057;
        border-radius: 50px;
        padding: 14px 32px;
        font-weight: 700;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-home:hover {
            background-color: #e2e6ea;
            transform: translateY(-3px);
            color: #212529;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

    /* Box hỗ trợ dưới cùng */
    .support-info {
        margin-top: 45px;
        padding-top: 25px;
        border-top: 1px solid #f1f3f5;
        color: #8795a1;
        font-size: 0.95rem;
    }

        .support-info a {
            color: #198754;
            text-decoration: none;
            font-weight: 700;
        }

            .support-info a:hover {
                text-decoration: underline;
            }
</style>

<div class="success-wrapper">
    <div class="container d-flex justify-content-center">
        <div class="success-card">

            <div class="success-icon-wrap">
                <i class="fas fa-check-circle success-icon"></i>
            </div>

            <h1 class="success-title">Đặt hàng thành công!</h1>
            <p class="success-text">
                Cảm ơn bạn đã tin tưởng và mua sắm tại <strong>Online Market</strong>.<br />
                Đơn hàng của bạn đã được ghi nhận và sẽ được xử lý trong thời gian sớm nhất.
            </p>

            <div class="order-code-box">
                <span>Mã đơn hàng của bạn</span>
                <h5>#@orderId</h5>
            </div>

            <div class="action-buttons">
                <a href="@Url.Action("OrderHistory", "Cart")" class="btn btn-track text-decoration-none">
                    <i class="fas fa-file-invoice me-2"></i> Quản lý đơn hàng
                </a>
                <a href="@Url.Action("Index", "Shop")" class="btn btn-home text-decoration-none">
                    <i class="fas fa-shopping-bag me-2"></i> Tiếp tục mua sắm
                </a>
            </div>

            <div class="support-info">
                Bạn cần hỗ trợ thêm? Vui lòng liên hệ Hotline: <a href="tel:19001234">1900 1234</a><br />
                hoặc gửi email về <a href="mailto:support@onlinemarket.com">support@onlinemarket.com</a>.
            </div>

        </div>
    </div>
</div>