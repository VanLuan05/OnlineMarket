@model CheckoutViewModel

@{
    ViewBag.Title = "Thanh toán đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .checkout-wrapper {
        padding: 40px 0;
    }

    .card-custom {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        background: #ffffff;
    }

    .icon-svg {
        width: 1.5rem;
        height: 1.5rem;
        margin-right: 10px;
        color: #198754; /* Màu xanh lá chuẩn Bootstrap Success */
    }

    .form-control {
        border-radius: 8px;
        padding: 10px 15px;
    }

        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
            border-color: #198754;
        }

    .form-label {
        font-weight: 500;
        color: #495057;
    }

    .btn-checkout {
        background-color: #198754;
        color: white;
        border-radius: 8px;
        padding: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: all 0.2s ease-in-out;
    }

        .btn-checkout:hover {
            background-color: #157347;
            color: white;
            transform: translateY(-2px);
        }
    /* Giữ tóm tắt đơn hàng luôn trượt theo màn hình */
    .order-summary-sticky {
        position: sticky;
        top: 30px;
    }

    .radio-card {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .radio-card:hover {
            border-color: #198754;
            background-color: #f8fff9;
        }
</style>

<div class="checkout-wrapper">
    <div class="container">
        @using (Html.BeginForm("Checkout", "Cart", FormMethod.Post, new { @class = "needs-validation", id = "checkoutForm" }))
        {
            @Html.AntiForgeryToken()
            <div class="row g-4">

                <div class="col-lg-8">

                    <div class="card card-custom p-4 mb-4">
                        <h4 class="mb-4 d-flex align-items-center fw-bold text-dark">
                            <svg class="icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Thông tin giao hàng
                        </h4>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.HoTenNhanHang, new { @class = "form-control", placeholder = "Ví dụ: Nguyễn Văn A", required = "required" })
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.SoDienThoai, new { @class = "form-control", placeholder = "Nhập số điện thoại liên hệ", required = "required" })
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.TinhThanh, new { @class = "form-control", placeholder = "VD: TP.HCM", required = "required" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Quận/Huyện <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.QuanHuyen, new { @class = "form-control", placeholder = "VD: Quận 1", required = "required" })
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Phường/Xã <span class="text-danger">*</span></label>
                                @Html.TextBoxFor(m => m.PhuongXa, new { @class = "form-control", placeholder = "VD: Bến Nghé", required = "required" })
                            </div>

                            <div class="col-12">
                                <label class="form-label">Địa chỉ chi tiết <span class="text-danger">*</span></label>
                                @Html.TextAreaFor(m => m.DiaChi, new { @class = "form-control", rows = "2", placeholder = "Nhập chi tiết: Số nhà, Tên đường...", required = "required" })
                            </div>
                            <div class="col-12">
                                <label class="form-label">Ghi chú thêm (Tùy chọn)</label>
                                @Html.TextAreaFor(m => m.GhiChu, new { @class = "form-control", rows = "2", placeholder = "Lưu ý cho tài xế giao hàng..." })
                            </div>
                        </div>
                    </div>

                    <div class="card card-custom p-4 mb-4">
                        <h4 class="mb-4 d-flex align-items-center fw-bold text-dark">
                            <svg class="icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                            Phương thức vận chuyển
                        </h4>

                        <div class="radio-card p-3 mb-3">
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input mt-0 me-3" style="width: 1.2rem; height: 1.2rem;" type="radio" name="PhuongThucGiaoHang" id="shipStandard" value="Giao hàng tiêu chuẩn" checked>
                                <label class="form-check-label w-100 cursor-pointer fw-semibold text-dark" for="shipStandard">
                                    Giao hàng tiêu chuẩn (20.000đ)
                                </label>
                            </div>
                        </div>

                        <div class="radio-card p-3">
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input mt-0 me-3" style="width: 1.2rem; height: 1.2rem;" type="radio" name="PhuongThucGiaoHang" id="shipFast" value="Giao hàng nhanh">
                                <label class="form-check-label w-100 cursor-pointer fw-semibold text-dark" for="shipFast">
                                    Giao hàng nhanh (30.000đ)
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="card card-custom p-4">
                        <h4 class="mb-4 d-flex align-items-center fw-bold text-dark">
                            <svg class="icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                            Phương thức thanh toán
                        </h4>

                        <div class="radio-card p-3 mb-3">
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input mt-0 me-3" style="width: 1.2rem; height: 1.2rem;" type="radio" name="HinhThucThanhToan" id="paymentCOD" value="COD" checked>
                                <label class="form-check-label w-100 cursor-pointer fw-semibold text-dark" for="paymentCOD">
                                    Thanh toán tiền mặt khi nhận hàng (COD)
                                </label>
                            </div>
                        </div>

                        <div class="radio-card p-3">
                            <div class="form-check d-flex align-items-center">
                                <input class="form-check-input mt-0 me-3" style="width: 1.2rem; height: 1.2rem;" type="radio" name="HinhThucThanhToan" id="paymentOnline" value="Online">
                                <label class="form-check-label w-100 cursor-pointer fw-semibold text-dark" for="paymentOnline">
                                    Chuyển khoản (VNPAY / Thẻ tín dụng)
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card card-custom p-4 order-summary-sticky">
                        <h4 class="mb-4 d-flex align-items-center fw-bold text-dark">
                            <svg class="icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                            Đơn hàng của bạn
                        </h4>

                        <div class="order-items mb-4" style="max-height: 350px; overflow-y: auto;">
                            @if (Model.CartItems != null && Model.CartItems.Any())
                            {
                                foreach (var item in Model.CartItems)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <div class="d-flex align-items-center pe-3">
                                            <div>
                                                <h6 class="mb-1 text-dark text-truncate" style="max-width: 180px;">@item.SanPham.TENSP</h6>
                                                <small class="text-muted">Số lượng: @item.SOLUONG</small>
                                            </div>
                                        </div>
                                        <span class="fw-bold text-dark">@String.Format("{0:0,0}", (item.SanPham.GIA ?? 0) * (item.SOLUONG ?? 0)) đ</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4 text-muted">
                                    <p>Giỏ hàng chưa có sản phẩm nào.</p>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính:</span>
                            <span class="fw-semibold">@String.Format("{0:0,0}", Model.TongTien) đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Phí vận chuyển:</span>
                            <span class="fw-semibold @(Model.PhiVanChuyen == 0 ? "text-success" : "")">
                                @(Model.PhiVanChuyen == 0 ? "Miễn phí" : String.Format("{0:0,0}", Model.PhiVanChuyen) + " đ")
                            </span>
                        </div>

                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                            <span class="text-muted">Thuế VAT (8%):</span>
                            <span class="fw-semibold">@String.Format("{0:0,0}", Model.VAT) đ</span>
                        </div>

                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between mb-3 text-success">
                                <span>Giảm giá (@Model.DiscountCode):</span>
                                <span class="fw-semibold">- @String.Format("{0:0,0}", Model.DiscountAmount) đ</span>
                            </div>
                        }

                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5 text-dark">Tổng thanh toán:</span>
                            <span class="fw-bold fs-4 text-danger">@String.Format("{0:0,0}", Model.TongThanhToan) đ</span>
                        </div>

                        <button type="submit" class="btn btn-checkout w-100 d-flex justify-content-center align-items-center">
                            ĐẶT HÀNG NGAY
                            <svg class="ms-2" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>
                    </div>
                </div>

            </div>
        }
    </div>
</div>

@section scripts {
    <script>
        // Trong Checkout.cshtml - phần scripts
$(document).ready(function () {
    // Áp dụng mã giảm giá
    $('#applyDiscountBtn').click(function () {
        var discountCode = $('#discountCodeInput').val().trim();
        if (!discountCode) {
            $('#discountMessage').html('<span class="text-danger">Vui lòng nhập mã giảm giá!</span>');
            return;
        }

        applyDiscountCode(discountCode);
    });

    // Xóa mã giảm giá
    $(document).on('click', '#removeDiscountBtn', function () {
        removeDiscount();
    });

    // Nhấn Enter để áp dụng mã
    $('#discountCodeInput').keypress(function (e) {
        if (e.which == 13) {
            e.preventDefault();
            $('#applyDiscountBtn').click();
        }
    });
});

// Hàm chọn mã từ danh sách
function selectDiscount(code, percent) {
    $('#discountCodeInput').val(code);
    $('#applyDiscountBtn').click();
}

// Hàm áp dụng mã giảm giá
function applyDiscountCode(discountCode) {
    $('#discountMessage').html('<span class="text-info"><i class="fas fa-spinner fa-spin"></i> Đang kiểm tra...</span>');

    $.ajax({
        url: '@Url.Action("ApplyDiscount", "Cart")',
        type: 'POST',
        data: { discountCode: discountCode },
        success: function (result) {
            if (result.success) {
                // Cập nhật UI
                $('#DiscountCode').val(discountCode);
                $('#DiscountAmount').val(result.discountAmount);

                // Cập nhật hiển thị
                updateCheckoutSummary(result);

                // Hiển thị thông báo
                $('#discountMessage').html('<span class="text-success"><i class="fas fa-check-circle"></i> ' + result.message + '</span>');

                // Hiển thị phần giảm giá
                updateDiscountDisplay(result.discountAmount, discountCode);

                // Hiển thị nút xóa mã
                if ($('#removeDiscountBtn').length === 0) {
                    $('#applyDiscountBtn').after(
                        '<button type="button" class="btn btn-danger ml-2" id="removeDiscountBtn">' +
                        '<i class="fas fa-times"></i> Xóa mã' +
                        '</button>'
                    );
                }
            } else {
                $('#discountMessage').html('<span class="text-danger"><i class="fas fa-exclamation-circle"></i> ' + result.message + '</span>');
                $('#DiscountCode').val('');
                $('#DiscountAmount').val(0);
            }
        },
        error: function () {
            $('#discountMessage').html('<span class="text-danger">Lỗi kết nối!</span>');
        }
    });
}

// Hàm xóa mã giảm giá
function removeDiscount() {
    $.ajax({
        url: '@Url.Action("RemoveDiscount", "Cart")',
        type: 'POST',
        success: function (result) {
            if (result.success) {
                // Reset UI
                resetDiscountUI(result);
            }
        }
    });
}

// Hàm cập nhật tóm tắt đơn hàng
function updateCheckoutSummary(result) {
    $('#shippingFee').text(formatCurrency(result.phiVanChuyen) + 'đ');
    $('#vatFee').text(formatCurrency(result.vat) + 'đ');
    $('#totalPayment').text(formatCurrency(result.tongThanhToan) + 'đ');
}

// Hàm cập nhật hiển thị giảm giá
function updateDiscountDisplay(discountAmount, discountCode) {
    if (discountAmount > 0 || discountCode.toUpperCase() === 'FREESHIP') {
        var displayText = '';
        if (discountAmount > 0) {
            displayText = '- ' + formatCurrency(discountAmount) + 'đ';
        } else if (discountCode.toUpperCase() === 'FREESHIP') {
            displayText = 'Miễn phí vận chuyển';
        }

        if ($('#discountDisplay').length === 0) {
            $('<div class="d-flex justify-content-between text-success" id="discountRow">' +
              '<span>Giảm giá:</span>' +
              '<span id="discountDisplay">' + displayText + '</span>' +
              '</div>').insertAfter('.card-body .d-flex:first');
        } else {
            $('#discountDisplay').text(displayText);
        }
    } else {
        $('#discountRow').remove();
    }
}

// Hàm reset UI khi xóa mã
function resetDiscountUI(result) {
    $('#discountCodeInput').val('');
    $('#DiscountCode').val('');
    $('#DiscountAmount').val(0);

    // Cập nhật hiển thị
    $('#shippingFee').text(formatCurrency(result.phiVanChuyen) + 'đ');
    $('#vatFee').text(formatCurrency(result.vat) + 'đ');
    $('#totalPayment').text(formatCurrency(result.tongThanhToan) + 'đ');

    // Xóa dòng giảm giá
    $('#discountRow').remove();

    // Xóa nút xóa mã
    $('#removeDiscountBtn').remove();

    // Thông báo
    $('#discountMessage').html('<span class="text-success"><i class="fas fa-check-circle"></i> ' + result.message + '</span>');
}

// Format tiền tệ
function formatCurrency(number) {
    if (!number) return '0';
    return number.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
}

        // Xử lý submit form
        $('#checkoutForm').submit(function (e) {
            e.preventDefault();
            var formData = $(this).serialize();
            var submitButton = $(this).find('button[type="submit"]');

            submitButton.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang xử lý...');

            $.ajax({
                url: '@Url.Action("PlaceOrder", "Cart")',
                type: 'POST',
                data: formData,
                success: function (result) {
                    if (result.success) {
                        window.location.href = '/Cart/OrderSuccess?orderId=' + result.orderId;
                    } else {
                        alert(result.message);
                        submitButton.prop('disabled', false).html('<i class="fas fa-check-circle"></i> Đặt hàng');
                    }
                },
                error: function () {
                    alert('Lỗi kết nối đến server!');
                    submitButton.prop('disabled', false).html('<i class="fas fa-check-circle"></i> Đặt hàng');
                }
            });
        });
    </script>
}