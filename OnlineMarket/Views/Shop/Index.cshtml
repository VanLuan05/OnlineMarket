@model List<OnlineMarket.SanPham>

@{
    ViewBag.Title = "Cửa Hàng - Fruit Store";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var search = ViewBag.Search as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
    var categories = ViewBag.Categories as List<OnlineMarket.DanhMuc> ?? new List<OnlineMarket.DanhMuc>();
    var priceSort = ViewBag.PriceSort as string ?? "";
    var nameSort = ViewBag.NameSort as string ?? "";
    var popularSort = ViewBag.PopularSort as string ?? "";
}

<style>
    .shop-section {
        background-color: #fbfbfb;
    }

    /* === SIDEBAR (CỘT TRÁI) === */
    .sidebar-widget {
        background: #ffffff;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        margin-bottom: 24px;
        border: 1px solid #f0f0f0;
    }

    .sidebar-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: #2c3e50;
        margin-bottom: 20px;
        position: relative;
        padding-bottom: 12px;
    }

        .sidebar-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 40px;
            height: 3px;
            background: #198754;
            border-radius: 2px;
        }

    /* Danh mục */
    .category-list a {
        display: block;
        padding: 10px 0;
        color: #555;
        text-decoration: none;
        transition: all 0.3s ease;
        border-bottom: 1px dashed #eaeaea;
        font-weight: 500;
    }

        .category-list a:last-child {
            border-bottom: none;
        }

        .category-list a:hover, .category-list a.active {
            color: #198754;
            padding-left: 8px;
            font-weight: 600;
        }

    /* Input tìm kiếm */
    .search-input-pill {
        border-radius: 50px 0 0 50px !important;
        padding-left: 20px;
    }

    .search-btn-pill {
        border-radius: 0 50px 50px 0 !important;
        padding-right: 20px;
    }

    /* === PRODUCT CARD (THẺ SẢN PHẨM) === */
    .product-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.04);
        transition: all 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
        }

    .product-img-wrap {
        position: relative;
        overflow: hidden;
        padding: 15px;
        background: #fff;
    }

        .product-img-wrap img {
            height: 200px;
            width: 100%;
            object-fit: contain;
            transition: transform 0.5s ease;
        }

    .product-card:hover .product-img-wrap img {
        transform: scale(1.08);
    }

    /* Badges */
    .badges-wrapper {
        position: absolute;
        top: 15px;
        left: 15px;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .badge-modern {
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    /* Hover Action Buttons */
    .hover-actions {
        position: absolute;
        bottom: -50px; /* Ẩn đi mặc định */
        left: 0;
        right: 0;
        display: flex;
        justify-content: center;
        gap: 12px;
        transition: bottom 0.3s ease;
        z-index: 3;
    }

    .product-card:hover .hover-actions {
        bottom: 20px; /* Trượt lên khi hover */
    }

    .btn-action-circle {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        color: #333;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .btn-action-circle:hover {
            background: #198754;
            color: #ffffff;
            transform: scale(1.1);
        }

    /* Product Info */
    .product-info {
        padding: 20px;
        text-align: center;
        border-top: 1px solid #f8f9fa;
    }

    .product-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c3e50;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 8px;
        transition: color 0.2s;
    }

        .product-title:hover {
            color: #198754;
        }

    .price-box {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        margin-top: 10px;
    }

    .price-main {
        font-size: 1.25rem;
        font-weight: 700;
        color: #e74c3c;
    }

    .price-unit {
        color: #7f8c8d;
        font-size: 0.9rem;
        font-weight: 500;
    }
</style>

<section class="breadcrumb-section bg-white py-3 border-bottom">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-success text-decoration-none"><i class="fas fa-home"></i> Trang Chủ</a></li>
                <li class="breadcrumb-item active text-muted">Cửa Hàng</li>
            </ol>
        </nav>
    </div>
</section>

<section class="shop-section py-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-lg-3">
                <div class="sidebar-widget">
                    <h5 class="sidebar-title">Tìm Kiếm</h5>
                    @using (Html.BeginForm("Index", "Shop", FormMethod.Get, new { @class = "search-form" }))
                    {
                        <div class="input-group">
                            <input type="text" name="search" class="form-control search-input-pill" placeholder="Tìm sản phẩm..." value="@search">
                            <button class="btn btn-success search-btn-pill" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                        <input type="hidden" name="categoryId" value="@categoryId" />
                        <input type="hidden" name="sortOrder" value="@priceSort" />
                    }
                </div>

                <div class="sidebar-widget">
                    <h5 class="sidebar-title">Danh Mục</h5>
                    <div class="category-list">
                        <a href="@Url.Action("Index", "Shop")" class="@(!categoryId.HasValue ? "active" : "")">
                            <i class="fas fa-angle-right me-2 fs-6"></i> Tất Cả Sản Phẩm
                        </a>
                        @foreach (var category in categories)
                        {
                            <a href="@Url.Action("Index", "Shop", new { categoryId = category.MADM })"
                               class="@(categoryId == category.MADM ? "active" : "")">
                                <i class="fas fa-angle-right me-2 fs-6"></i> @(category.TENDM ?? "Danh mục")
                            </a>
                        }
                    </div>
                </div>

                <div class="sidebar-widget">
                    <h5 class="sidebar-title">Sắp Xếp</h5>
                    <div class="category-list">
                        <a href="@Url.Action("Index", "Shop", new { sortOrder = "" })" class="@(string.IsNullOrEmpty(priceSort) ? "active" : "")">
                            Mặc Định
                        </a>
                        <a href="@Url.Action("Index", "Shop", new { sortOrder = "price_asc" })" class="@(priceSort == "price_asc" ? "active" : "")">
                            <i class="fas fa-arrow-up text-success me-1"></i> Giá: Thấp đến Cao
                        </a>
                        <a href="@Url.Action("Index", "Shop", new { sortOrder = "price_desc" })" class="@(priceSort == "price_desc" ? "active" : "")">
                            <i class="fas fa-arrow-down text-danger me-1"></i> Giá: Cao đến Thấp
                        </a>
                        <a href="@Url.Action("Index", "Shop", new { sortOrder = "name_asc" })" class="@(nameSort == "name_asc" ? "active" : "")">
                            <i class="fas fa-sort-alpha-down text-info me-1"></i> Tên: A - Z
                        </a>
                        <a href="@Url.Action("Index", "Shop", new { sortOrder = "popular_desc" })" class="@(popularSort == "popular_desc" ? "active" : "")">
                            <i class="fas fa-fire text-warning me-1"></i> Bán Chạy Nhất
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 bg-white p-3 rounded-3 shadow-sm border border-light">
                    <h2 class="h4 mb-0 fw-bold text-dark">
                        @if (categoryId.HasValue)
                        {
                            var currentCategory = categories.FirstOrDefault(c => c.MADM == categoryId);
                            if (currentCategory != null && !string.IsNullOrEmpty(currentCategory.TENDM))
                            {
                                @currentCategory.TENDM
                            }
                            else
                            {
                                <text>Sản Phẩm</text>
                            }
                        }
                        else
                        {
                            <text>Tất Cả Sản Phẩm</text>
                        }
                    </h2>
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 fs-6 rounded-pill">
                        Hiển thị <strong>@(Model?.Count ?? 0)</strong> kết quả
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(search))
                {
                    <div class="alert alert-success bg-success bg-opacity-10 border-0 mb-4 d-flex justify-content-between align-items-center">
                        <div><i class="fas fa-search me-2"></i> Kết quả tìm kiếm cho: <strong class="text-dark">"@search"</strong></div>
                        <a href="@Url.Action("Index", "Shop")" class="btn btn-sm btn-success rounded-pill">Xóa lọc</a>
                    </div>
                }

                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var product in Model)
                        {
                            <div class="col-xl-4 col-lg-4 col-md-6 col-sm-6">
                                <div class="product-card h-100">

                                    <div class="product-img-wrap">
                                        <div class="badges-wrapper">
                                            @if ((product.LUOTMUA ?? 0) > 100)
                                            {
                                                <span class="badge badge-modern bg-danger text-white"><i class="fas fa-fire"></i> BÁN CHẠY</span>
                                            }
                                            @if ((product.GIA) < 50000)
                                            {
                                                <span class="badge badge-modern bg-success text-white">GIÁ TỐT</span>
                                            }
                                        </div>

                                        <a href="@Url.Action("Details", "Shop", new { id = product.MASP })">
                                            <img src="@product.URL_ANH" alt="@product.TENSP">
                                        </a>

                                        <div class="hover-actions">
                                            @if (product.TRANGTHAI == "Còn hàng")
                                            {
                                                <button class="btn-action-circle add-to-cart"
                                                        data-product-id="@product.MASP"
                                                        data-product-name="@product.TENSP"
                                                        data-product-price="@product.GIA"
                                                        title="Thêm vào giỏ">
                                                    <i class="fas fa-shopping-cart"></i>
                                                </button>
                                            }
                                            <a href="@Url.Action("Details", "Shop", new { id = product.MASP })" class="btn-action-circle" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </div>
                                    </div>

                                    <div class="product-info">
                                        <div class="product-rating mb-2 text-warning" style="font-size: 0.85rem;">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            <span class="text-muted ms-1">(@(product.LUOTMUA ?? 0))</span>
                                        </div>

                                        <a href="@Url.Action("Details", "Shop", new { id = product.MASP })" class="product-title">
                                            @(product.TENSP ?? "Tên sản phẩm")
                                        </a>

                                        <div class="price-box">
                                            <span class="price-main">@string.Format("{0:N0}đ", product.GIA)</span>
                                            <span class="price-unit">/ @(product.DONVITINH ?? "kg")</span>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-white rounded-3 shadow-sm border border-light mt-4">
                        <img src="~/Content/img/logo.jpg" alt="No products" class="mb-4" style="width: 150px; opacity: 0.5; border-radius: 50%;">
                        <h4 class="text-dark fw-bold">Không tìm thấy sản phẩm nào!</h4>
                        <p class="text-muted mb-4">Rất tiếc, không có sản phẩm nào phù hợp với tìm kiếm của bạn.</p>
                        <a href="@Url.Action("Index", "Shop")" class="btn btn-success px-4 py-2 rounded-pill shadow-sm">
                            <i class="fas fa-sync-alt me-2"></i> Quay lại cửa hàng
                        </a>
                    </div>
                }
            </div>

        </div>
    </div>
</section>

@section scripts {
    <script>
        $(document).ready(function () {
            // Logic thêm vào giỏ hàng (Giữ nguyên của bạn)
            $(document).on('click', '.add-to-cart', function () {
                const productId = $(this).data('product-id');
                const productName = $(this).data('product-name');
                const cartUrl = '@Url.Action("AddToCart", "Cart")';

                if (!cartUrl) {
                    showAlert('error', 'Chức năng giỏ hàng chưa khả dụng!');
                    return;
                }

                // Thêm hiệu ứng xoay (loading) cho nút khi bấm
                let btn = $(this);
                let originalIcon = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin"></i>');
                btn.prop('disabled', true);

                $.post(cartUrl, {
                    productId: productId,
                    quantity: 1
                }).done(function (response) {
                    if (response && response.success) {
                        showAlert('success', `Đã thêm "${productName}" vào giỏ hàng!`);
                        if (response.cartCount) {
                            updateCartCount(response.cartCount);
                        }
                    } else {
                        showAlert('error', response ? response.message : 'Có lỗi xảy ra!');
                    }
                }).fail(function () {
                    showAlert('error', 'Có lỗi xảy ra khi thêm vào giỏ hàng!');
                }).always(function() {
                    // Phục hồi lại nút
                    btn.html(originalIcon);
                    btn.prop('disabled', false);
                });
            });

            // Hiển thị thông báo (Toast UI hiện đại hơn)
            function showAlert(type, message) {
                $('.alert-position-fixed').remove();
                const alertClass = type === 'success' ? 'bg-success' : 'bg-danger';
                const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle';

                const alertHtml = `
                    <div class="alert ${alertClass} text-white alert-dismissible fade show alert-position-fixed shadow-lg"
                         style="position: fixed; top: 30px; right: 30px; z-index: 9999; min-width: 320px; border-radius: 10px; border: none;">
                        <div class="d-flex align-items-center">
                            <i class="fas ${icon} fs-4 me-3"></i>
                            <div class="fw-medium">${message}</div>
                        </div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" style="top: 50%; transform: translateY(-50%);"></button>
                    </div>`;

                $('body').append(alertHtml);
                setTimeout(() => {
                    $('.alert-position-fixed').fadeOut(500, function() { $(this).remove(); });
                }, 3500);
            }

            // Cập nhật số lượng giỏ hàng
            function updateCartCount(count) {
                const cartCount = $('#cart-count');
                if (cartCount.length) {
                    cartCount.text(count);
                    // Hiệu ứng giật nhẹ khi số lượng tăng
                    cartCount.addClass('scale-up');
                    setTimeout(() => cartCount.removeClass('scale-up'), 300);
                }
            }
        });
    </script>
    <style>
        .scale-up {
            transform: scale(1.5);
            transition: transform 0.2s;
            display: inline-block;
        }
    </style>
}