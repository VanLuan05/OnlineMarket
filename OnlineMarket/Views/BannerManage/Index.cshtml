@model IEnumerable<OnlineMarket.Models.Banner>
@{
    ViewBag.Title = "Quản lý Banner";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Hoặc _AdminLayout nếu có
}

<div class="container mt-4">
    <h2>Quản lý Banner</h2>
    <a href="@Url.Action("Create")" class="btn btn-success mb-3"><i class="fa fa-plus"></i> Thêm Banner mới</a>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Hình ảnh</th>
                <th>Tên Banner</th>
                <th>Thứ tự</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
            <tr>
                <td style="width: 150px;">
                    <img src="@Url.Content("~/Content/img/" + item.HinhAnh)" style="width: 100%; height: auto; border-radius: 5px;" />
                </td>
                <td>
                    <strong>@item.TenBanner</strong><br />
                    <small class="text-muted">@item.MoTa</small>
                </td>
                <td class="text-center">@item.ThuTu</td>
                <td class="text-center">
                    @if (item.HienThi) { <span class="badge bg-success">Hiện</span> }
                        else { <span class="badge bg-secondary">Ẩn</span> }
                </td>
                <td class="text-center">
                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-primary btn-sm"><i class="fa fa-edit"></i> Sửa</a>
                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc muốn xóa?');"><i class="fa fa-trash"></i> Xóa</a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>