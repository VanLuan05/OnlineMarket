@{
    ViewBag.Title = "Blog - Tin Tức Trái Cây";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- CSS cho Blog -->
<style>
    :root {
        --primary-color: #2e8b57;
        --secondary-color: #ff6b6b;
        --accent-color: #4ecdc4;
        --dark-color: #2c3e50;
        --light-color: #f8f9fa;
        --text-color: #333;
        --text-light: #6c757d;
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 15px 40px rgba(0, 0, 0, 0.15);
        --transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
    }

    /* Blog Hero Section */
    .blog-hero {
        background: linear-gradient(135deg, rgba(46, 139, 87, 0.9), rgba(78, 205, 196, 0.8)),
                    url('@Url.Content("~/Content/img/blog/hero-bg.jpg")') center/cover no-repeat;
        color: white;
        padding: 100px 0 60px;
        text-align: center;
        margin-bottom: 60px;
        position: relative;
        overflow: hidden;
    }

    .blog-hero:before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23ffffff" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,112C672,96,768,96,864,112C960,128,1056,160,1152,160C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') bottom/cover no-repeat;
    }

    .blog-hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 20px;
        position: relative;
        z-index: 1;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .blog-hero p {
        font-size: 1.2rem;
        max-width: 700px;
        margin: 0 auto 30px;
        opacity: 0.95;
        position: relative;
        z-index: 1;
    }

    /* Animated Heading */
    .heading {
        text-align: center;
        margin: 60px 0;
        position: relative;
    }

    .heading .title-text {
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--dark-color);
        position: relative;
        padding: 0 30px;
        display: inline-block;
        background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .heading .title-text:before,
    .heading .title-text:after {
        content: '';
        position: absolute;
        top: 50%;
        width: 80px;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
        border-radius: 2px;
    }

    .heading .title-text:before {
        right: 100%;
        margin-right: 20px;
    }

    .heading .title-text:after {
        left: 100%;
        margin-left: 20px;
    }

    /* Blog Content */
    .blog-content {
        padding: 30px 0 80px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        min-height: 100vh;
    }

    /* Blog Filter */
    .blog-filter {
        max-width: 1200px;
        margin: 0 auto 50px;
        padding: 0 20px;
    }

    .filter-container {
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 12px 25px;
        background: white;
        border: 2px solid #e0e0e0;
        border-radius: 50px;
        font-weight: 600;
        color: var(--text-light);
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
        transform: translateY(-3px);
        box-shadow: var(--shadow);
    }

    .filter-btn i {
        font-size: 0.9rem;
    }

    /* Blog Grid */
    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Blog Card */
    .blog-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: var(--transition);
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .blog-card:hover {
        transform: translateY(-15px);
        box-shadow: var(--shadow-hover);
    }

    .blog-card:hover .blog-image:after {
        opacity: 0.3;
    }

    /* Blog Image */
    .blog-image {
        height: 250px;
        position: relative;
        overflow: hidden;
    }

    .blog-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .blog-card:hover .blog-image img {
        transform: scale(1.1);
    }

    .blog-image:after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
        opacity: 0;
        transition: opacity 0.4s ease;
        mix-blend-mode: multiply;
    }

    /* Category Badge */
    .category-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: var(--secondary-color);
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        z-index: 2;
        box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    }

    /* Blog Info */
    .blog-info {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .blog-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        font-size: 0.9rem;
        color: var(--text-light);
    }

    .blog-date {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .blog-read-time {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .blog-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--dark-color);
        margin-bottom: 15px;
        line-height: 1.4;
        flex-grow: 1;
        transition: color 0.3s ease;
    }

    .blog-card:hover .blog-title {
        color: var(--primary-color);
    }

    .blog-excerpt {
        color: var(--text-light);
        line-height: 1.6;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Blog Footer */
    .blog-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 25px;
        border-top: 1px solid #eee;
        background: #f9f9f9;
    }

    .blog-author {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .author-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
    }

    .author-info h5 {
        margin: 0;
        font-size: 0.9rem;
        color: var(--dark-color);
    }

    .author-info p {
        margin: 0;
        font-size: 0.8rem;
        color: var(--text-light);
    }

    /* Read More Button */
    .read-more-btn {
        background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .read-more-btn:hover {
        transform: translateX(10px);
        box-shadow: 0 8px 25px rgba(46, 139, 87, 0.3);
    }

    /* Pagination */
    .blog-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        margin-top: 60px;
        padding: 20px;
    }

    .pagination-btn {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e0e0e0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        font-weight: 600;
        color: var(--dark-color);
    }

    .pagination-btn:hover,
    .pagination-btn.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
        transform: translateY(-3px);
    }

    /* Featured Post */
    .featured-post {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
        margin-bottom: 30px;
    }

    .featured-image {
        height: 400px;
    }

    .featured-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .featured-content {
        padding: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .featured-badge {
        background: var(--secondary-color);
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        display: inline-block;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 20px;
        width: fit-content;
    }

    .featured-title {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--dark-color);
        margin-bottom: 20px;
        line-height: 1.2;
    }

    /* Newsletter */
    .newsletter-section {
        background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
        color: white;
        padding: 60px 20px;
        border-radius: 20px;
        margin: 80px auto 40px;
        max-width: 800px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .newsletter-section:before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23ffffff" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,112C672,96,768,96,864,112C960,128,1056,160,1152,160C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') center/cover no-repeat;
        animation: float 20s linear infinite;
    }

    @@keyframes float {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .newsletter-content {
        position: relative;
        z-index: 2;
    }

    .newsletter-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 20px;
    }

    .newsletter-form {
        display: flex;
        gap: 15px;
        max-width: 500px;
        margin: 30px auto 0;
    }

    .newsletter-input {
        flex: 1;
        padding: 15px 25px;
        border: none;
        border-radius: 50px;
        font-size: 1rem;
        outline: none;
    }

    .newsletter-btn {
        background: var(--dark-color);
        color: white;
        border: none;
        padding: 15px 40px;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
    }

    .newsletter-btn:hover {
        background: white;
        color: var(--primary-color);
        transform: translateY(-3px);
    }

    /* Loading Animation */
    .loading {
        text-align: center;
        padding: 40px;
        display: none;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 20px;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Responsive Design */
    @@media (max-width: 992px) {
        .featured-post {
            grid-template-columns: 1fr;
        }

        .featured-image {
            height: 300px;
        }

        .blog-hero h1 {
            font-size: 2.8rem;
        }
    }

    @@media (max-width: 768px) {
        .blog-grid {
            grid-template-columns: 1fr;
            padding: 0 15px;
        }

        .blog-hero {
            padding: 80px 0 40px;
        }

        .blog-hero h1 {
            font-size: 2.2rem;
        }

        .heading .title-text {
            font-size: 2.2rem;
        }

        .newsletter-form {
            flex-direction: column;
        }

        .filter-container {
            justify-content: center;
        }

        .filter-btn {
            padding: 10px 20px;
            font-size: 0.9rem;
        }
    }

    @@media (max-width: 480px) {
        .blog-footer {
            flex-direction: column;
            gap: 15px;
            align-items: flex-start;
        }

        .featured-title {
            font-size: 1.8rem;
        }

        .heading .title-text {
            font-size: 1.8rem;
        }
    }
</style>

<!-- Blog Hero Section -->
<section class="blog-hero">
    <div class="container">
        <h1>Khám Phá Thế Giới Trái Cây</h1>
        <p>Cập nhật những kiến thức bổ ích, công thức chế biến độc đáo và tin tức mới nhất về thế giới trái cây tươi ngon</p>
        <div class="search-box" style="max-width: 500px; margin: 0 auto;">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Tìm kiếm bài viết..." style="border-radius: 25px 0 0 25px; padding: 15px 25px; border: none;">
                <button class="btn btn-primary" style="border-radius: 0 25px 25px 0; padding: 15px 30px;">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Blog Content -->
<main class="blog-content">
    <!-- Animated Heading -->
    <div class="heading">
        <span class="title-text">TIN TỨC MỚI NHẤT</span>
    </div>

    <!-- Blog Filter -->
    <div class="blog-filter">
        <div class="filter-container">
            <button class="filter-btn active" data-filter="all">
                <i class="fas fa-th-large"></i> Tất cả
            </button>
            <button class="filter-btn" data-filter="health">
                <i class="fas fa-heartbeat"></i> Sức khỏe
            </button>
            <button class="filter-btn" data-filter="nutrition">
                <i class="fas fa-apple-alt"></i> Dinh dưỡng
            </button>
            <button class="filter-btn" data-filter="import">
                <i class="fas fa-globe-asia"></i> Nhập khẩu
            </button>
            <button class="filter-btn" data-filter="recipe">
                <i class="fas fa-utensils"></i> Công thức
            </button>
            <button class="filter-btn" data-filter="tips">
                <i class="fas fa-lightbulb"></i> Mẹo vặt
            </button>
        </div>
    </div>

    <!-- Blog Grid -->
    <div class="blog-grid">
        <!-- Featured Post -->
        <article class="featured-post" data-category="health">
            <div class="featured-image">
                <img src="@Url.Content("~/Content/img/blog/Trái Cây và Sức Khỏe Tim Mạch.png")" alt="Trái cây và sức khỏe tim mạch">
                <span class="featured-badge">Bài viết nổi bật</span>
            </div>
            <div class="featured-content">
                <span class="category-badge">Sức khỏe</span>
                <h2 class="featured-title">Trái Cây và Sức Khỏe Tim Mạch: Bí Quyết Tự Nhiên Để Bảo Vệ Trái Tim Bạn</h2>
                <div class="blog-meta">
                    <span class="blog-date"><i class="far fa-calendar"></i> 15/12/2024</span>
                    <span class="blog-read-time"><i class="far fa-clock"></i> 5 phút đọc</span>
                </div>
                <p class="blog-excerpt">Tim là cơ quan quan trọng hàng đầu trong cơ thể, chịu trách nhiệm bơm máu và cung cấp oxy cho toàn bộ hệ thống. Một chế độ ăn uống lành mạnh, giàu trái cây tươi, có thể giúp bạn bảo vệ và tăng cường sức khỏe tim mạch một cách tự nhiên.</p>
                <div class="blog-footer">
                    <div class="blog-author">
                        <div class="author-avatar">LT</div>
                        <div class="author-info">
                            <h5>Dr. Lan Trinh</h5>
                            <p>Chuyên gia dinh dưỡng</p>
                        </div>
                    </div>
                    <a href="@Url.Action("BlogDetail", "Home", new { id = 1 })" class="read-more-btn">
                        Đọc ngay <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </article>

        <!-- Regular Blog Posts -->
        <article class="blog-card" data-category="health">
            <div class="blog-image">
                <img src="@Url.Content("~/Content/img/blog/Lợi ích vượt trội của quả vú sữa.png")" alt="Lợi ích vượt trội của quả vú sữa">
                <span class="category-badge">Sức khỏe</span>
            </div>
            <div class="blog-info">
                <div class="blog-meta">
                    <span class="blog-date"><i class="far fa-calendar"></i> 12/12/2024</span>
                    <span class="blog-read-time"><i class="far fa-clock"></i> 4 phút đọc</span>
                </div>
                <h3 class="blog-title">Lợi Ích Vượt Trội Của Quả Vú Sữa - Trái Cây Việt Nam Được Thế Giới Ưa Chuộng</h3>
                <p class="blog-excerpt">Vú sữa là loại trái cây được người Việt Nam sử dụng hàng trăm năm trước. Theo Cục Bảo vệ thực vật, đây là một trong những loại trái cây có giá trị dinh dưỡng cao nhất.</p>
            </div>
            <div class="blog-footer">
                <div class="blog-author">
                    <div class="author-avatar">NH</div>
                    <div class="author-info">
                        <h5>Ngọc Hà</h5>
                        <p>Chuyên gia ẩm thực</p>
                    </div>
                </div>
                <a href="@Url.Action("BlogDetail", "Home", new { id = 2 })" class="read-more-btn">
                    Xem thêm <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </article>

        <article class="blog-card" data-category="nutrition">
            <div class="blog-image">
                <img src="@Url.Content("~/Content/img/blog/Trái Cây Dinh Dưỡng.png")" alt="Trái cây dinh dưỡng">
                <span class="category-badge">Dinh dưỡng</span>
            </div>
            <div class="blog-info">
                <div class="blog-meta">
                    <span class="blog-date"><i class="far fa-calendar"></i> 10/12/2024</span>
                    <span class="blog-read-time"><i class="far fa-clock"></i> 6 phút đọc</span>
                </div>
                <h3 class="blog-title">3 Loại Trái Cây Tăng Dinh Dưỡng Khi Nấu Chín - Bí Quyết Vàng Cho Sức Khỏe</h3>
                <p class="blog-excerpt">Không chỉ tươi, nhiều loại trái cây khi nấu chín lại trở thành "thần dược" giúp tăng cường dinh dưỡng và hỗ trợ nhiều bệnh lý khác nhau.</p>
            </div>
            <div class="blog-footer">
                <div class="blog-author">
                    <div class="author-avatar">TH</div>
                    <div class="author-info">
                        <h5>Trần Hương</h5>
                        <p>Đầu bếp dinh dưỡng</p>
                    </div>
                </div>
                <a href="@Url.Action("BlogDetail", "Home", new { id = 3 })" class="read-more-btn">
                    Xem thêm <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </article>

        <article class="blog-card" data-category="import">
            <div class="blog-image">
                <img src="@Url.Content("~/Content/img/blog/Trái Cây nhập khẩu.png")" alt="các loại trái cây nhập khẩu">
                <span class="category-badge">Nhập khẩu</span>
            </div>
            <div class="blog-info">
                <div class="blog-meta">
                    <span class="blog-date"><i class="far fa-calendar"></i> 08/12/2024</span>
                    <span class="blog-read-time"><i class="far fa-clock"></i> 5 phút đọc</span>
                </div>
                <h3 class="blog-title">6 Loại Trái Cây Nhập Khẩu Giúp Tăng Cường Sức Khỏe Mùa Hè</h3>
                <p class="blog-excerpt">Mùa hè đang đến gần, việc bổ sung trái cây vào chế độ ăn uống hằng ngày là cách tuyệt vời để duy trì sức khỏe và tăng cường hệ miễn dịch.</p>
            </div>
            <div class="blog-footer">
                <div class="blog-author">
                    <div class="author-avatar">QT</div>
                    <div class="author-info">
                        <h5>Quốc Thịnh</h5>
                        <p>Nhà nhập khẩu</p>
                    </div>
                </div>
                <a href="@Url.Action("BlogDetail", "Home", new { id = 4 })" class="read-more-btn">
                    Xem thêm <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </article>

