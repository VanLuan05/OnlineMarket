@model List<OnlineMarket.SanPham>
    @{
        ViewBag.Title = "Trang Chủ - Fruit Store";
        Layout = "~/Views/Shared/_Layout.cshtml";
    }

    <section id="hero-banner" style="width: 100%">
        @Html.Action("BannerPartial", "Home")
    </section>

    <section id="feature" class="section-p1">
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f1.png")">
            <h6>Miễn phí vận chuyển</h6>
        </div>
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f2.png")">
            <h6>Đặt hàng trực tuyến</h6>
        </div>
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f3.png")">
            <h6>Tiết kiệm tiền</h6>
        </div>
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f4.png")">
            <h6>Khuyến mãi</h6>
        </div>
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f5.png")">
            <h6>Bán vui vẻ</h6>
        </div>
        <div class="fe-box">
            <img src="@Url.Content("~/Content/img/features/f6.png")">
            <h6>Hỗ trợ 24/7</h6>
        </div>
    </section>

    <section id="product1" class="container py-5">
        <div class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
            <h3 class="fw-bold text-dark mb-0 d-flex align-items-center">
                <svg width="28" height="28" fill="none"  stroke-width="2" viewBox="0 0 24 24" class="me-2"><path d="M12 2c0 0-5 3.5-5 9 0 4.5 5 11 5 11s5-6.5 5-11c0-5.5-5-9-5-9z" /><path d="M12 11c-1.5 0-3 1.5-3 3 0 2.5 3 6 3 6s3-3.5 3-6c0-1.5-1.5-3-3-3z" /></svg>
                Sản Phẩm Nổi Bật
            </h3>
            <a href="@Url.Action("Index", "Shop")" class="text-success text-decoration-none fw-semibold" style="font-size: 15px;">
                Xem tất cả <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" /></svg>
            </a>
        </div>

        <div class="row g-4">
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <div class="col-xl-3 col-lg-3 col-md-4 col-sm-6 col-6">
                        <div class="pro position-relative h-100 d-flex flex-column">
                            <a href="@Url.Action("Details", "Shop", new { id = item.MASP })" class="text-center">
                                <img src="@item.URL_ANH" alt="@item.TENSP" class="img-fluid" style="border-radius: 10px; max-height: 200px; object-fit: cover; width: 100%;">
                            </a>
                            <div class="des d-flex flex-column flex-grow-1 mt-3">
                                <h5 class="mb-2">
                                    <a href="@Url.Action("Details", "Shop", new { id = item.MASP })" style="text-decoration: none; color: inherit; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @item.TENSP
                                    </a>
                                </h5>
                                <div class="star text-warning mb-2">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                </div>
                                <h4 class="text-danger fw-bold mt-auto mb-0" style="font-size: 18px;">@string.Format("{0:N0}đ", item.GIA)</h4>
                            </div>

                            <a href="javascript:void(0);"
                               class="cart btn-add-to-cart-home shadow-sm"
                               data-product-id="@item.MASP"
                               data-product-name="@item.TENSP">
                                <i class="fa-solid fa-cart-plus"></i>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <section id="sm-banner" class="section-p1">
        <div class="banner-box">
            <h2>Ưu Đãi</h2>
            <h1>Cho các dịp lễ</h1>
            <span>Giảm giá siêu hời cho các đơn hàng quà tặng</span>
            <button class="white">Tìm hiểu thêm</button>
        </div>
        <div class="banner-box banner-box2">
            <h2>Quà Tặng</h2>
            <h1>Khách hàng VIP</h1>
            <span>Đăng ký trở thành hội viên để nhận các ưu đãi đặc biệt</span>
            <a href="#">
                <button class="white">Tìm hiểu thêm</button>
            </a>
        </div>
    </section>

    <section id="banner3">
        <div class="banner-box">
            <h2>Mùa hoa quả</h2>
            <span>Ăn thả ga không lo về giá</span>
        </div>
        <div class="banner-box banner-box2">
            <h2>Thực phẩm tươi</h2>
            <span>Nguồn thực phẩm nhập khẩu siêu chất lượng</span>
        </div>
        <div class="banner-box banner-box3">
            <h2>Thực phẩm chế biến sẵn</h2>
            <span>Bữa ăn gia đình đầm ấm đã được chế biến</span>
        </div>
    </section>

    <section id="newsletter" class="section-p1 section-m1">
        <div class="newstext">
            <h4>Đăng Ký Nhận Thông Tin</h4>
            <p>Nhận thông tin cập nhật mới nhất qua Email về cửa hàng của chúng tôi và <span>các ưu đãi đặc biệt</span></p>
        </div>
        <div class="form">
            <input type="text" placeholder="Địa chỉ email của bạn">
            <button class="normal">Đăng ký</button>
        </div>
    </section>

    @section scripts {
        <script>
        $(document).ready(function () {
            // Xử lý sự kiện click vào nút Thêm vào giỏ hàng tại Trang chủ
            $('.btn-add-to-cart-home').click(function (e) {
                e.preventDefault();

                const btn = $(this);
                const productId = btn.data('product-id');
                const productName = btn.data('product-name');

                // Hiệu ứng UX: Đổi icon thành loading khi đang xử lý
                const originalIcon = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin text-success"></i>');
                btn.css('pointer-events', 'none');

                // Gọi AJAX xuống CartController -> AddToCart
                $.post('@Url.Action("AddToCart", "Cart")', {
                    productId: productId,
                    quantity: 1
                }).done(function (response) {
                    if (response.success) {
                        showAlert('success', `Đã thêm "${productName}" vào giỏ hàng!`);

                        // Cập nhật con số giỏ hàng trên thanh Navbar
                        if (response.cartCount !== undefined) {
                            $('#cart-count').text(response.cartCount);
                            $('#cart-count').addClass('scale-up');
                            setTimeout(() => $('#cart-count').removeClass('scale-up'), 300);
                        }
                    } else {
                        // Nếu chưa đăng nhập, chuyển hướng sang trang Đăng nhập
                        if (response.message === "Vui lòng đăng nhập!") {
                            window.location.href = '@Url.Action("Login", "Account")';
                        } else {
                            showAlert('error', response.message);
                        }
                    }
                }).fail(function () {
                    showAlert('error', 'Lỗi kết nối đến máy chủ. Vui lòng thử lại!');
                }).always(function () {
                    // Trả lại icon giỏ hàng ban đầu
                    btn.html(originalIcon);
                    btn.css('pointer-events', 'auto');
                });
            });

            // Hàm hiển thị thông báo Toast UI nổi
            function showAlert(type, message) {
                $('.alert-position-fixed').remove();
                const alertClass = type === 'success' ? 'bg-success text-white' : 'bg-danger text-white';
                const iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle';

                const alertHtml = `
                    <div class="alert ${alertClass} alert-dismissible fade show alert-position-fixed shadow-lg"
                         style="position: fixed; top: 30px; right: 30px; z-index: 9999; min-width: 320px; border-radius: 10px; border: none;">
                        <div class="d-flex align-items-center">
                            <i class="fas ${iconClass} fs-4 me-3"></i>
                            <div class="fw-medium">${message}</div>
                        </div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" style="top: 50%; transform: translateY(-50%);"></button>
                    </div>`;

                $('body').append(alertHtml);
                setTimeout(() => {
                    $('.alert-position-fixed').fadeOut(500, function() { $(this).remove(); });
                }, 3500);
            }
        });
        </script>

        <style>
            /* Hiệu ứng nảy giỏ hàng */
            .scale-up {
                transform: scale(1.5);
                transition: transform 0.2s;
                display: inline-block;
            }

            /* Hiệu ứng nổi thẻ sản phẩm trang chủ */
            .pro {
                transition: all 0.3s ease;
            }

                .pro:hover {
                    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                    transform: translateY(-5px);
                }
            /* CSS Fix: Căn đều 2 bên và tối ưu chiều cao cho thẻ Sản phẩm */
            .pro {
                width: 100% !important; /* Ghi đè chiều rộng cũ để Bootstrap tự chia cột */
                margin: 0 !important; /* Xóa margin cũ gây lệch Grid */
                padding: 15px !important;
                background: #fff;
                border: 1px solid #ececec;
                border-radius: 15px;
                transition: all 0.3s ease;
            }

                .pro:hover {
                    box-shadow: 0 8px 25px rgba(0,0,0,0.08);
                    transform: translateY(-5px);
                    border-color: #05a569; /* Đổi màu viền khi đưa chuột vào */
                }

                /* Định dạng nút giỏ hàng nổi bật hơn */
                .pro .cart {
                    width: 40px;
                    height: 40px;
                    line-height: 40px;
                    border-radius: 50px;
                    background-color: #e8f6ea;
                    color: #088178;
                    border: 1px solid #cce7d0;
                    position: absolute;
                    bottom: 15px;
                    right: 15px;
                    text-align: center;
                    transition: all 0.3s ease;
                }

                    .pro .cart:hover {
                        background-color: #088178;
                        color: #fff;
                    }
        </style>
    }
    <script>
        (function () { if (!window.chatbase || window.chatbase("getState") !== "initialized") { window.chatbase = (...arguments) => { if (!window.chatbase.q) { window.chatbase.q = [] } window.chatbase.q.push(arguments) }; window.chatbase = new Proxy(window.chatbase, { get(target, prop) { if (prop === "q") { return target.q } return (...args) => target(prop, ...args) } }) } const onLoad = function () { const script = document.createElement("script"); script.src = "https://www.chatbase.co/embed.min.js"; script.id = "ZOPcsIkIn74PDTE4341Yf"; script.domain = "www.chatbase.co"; document.body.appendChild(script) }; if (document.readyState === "complete") { onLoad() } else { window.addEventListener("load", onLoad) } })();
    </script>
