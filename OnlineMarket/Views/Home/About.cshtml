
@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            color: #333;
            margin: 0;
            overflow-x: hidden;
            line-height: 1.6;
        }
        #header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 30px;
            background: #ffffff;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo {
            height: 60px;
            transition: transform 0.3s ease;
        }
        .logo:hover {
            transform: scale(1.1);
        }
        #navbar {
            list-style: none;
            display: flex;
            gap: 20px;
            margin: 0;
        }
        #navbar li a {
            text-decoration: none;
            color: #333;
            font-size: 16px;
            font-weight: 500;
            transition: color 0.3s ease;
        }
        #navbar li a:hover, #navbar li a.active {
            color: #28a745;
        }
        #navbar #close {
            display: none;
        }
        #mobile {
            display: none;
            align-items: center;
            gap: 20px;
        }
        #about {
            padding: 80px 0;
            position: relative;
            background: url('https://cdn.pixabay.com/photo/2017/08/30/01/05/milky-way-2695569_1280.jpg') no-repeat center/cover fixed;
            overflow: hidden;
        }
        .about-overlay {
            background: rgba(0, 0, 0, 0.5);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }
        .section-title {
            font-size: 48px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 40px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
            animation: fadeInDown 1s ease;
        }
        @@keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .intro, .history, .team, .values, .certifications {
            margin-bottom: 60px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 10px;
transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .intro:hover, .history:hover, .team:hover, .values:hover, .certifications:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .intro p, .history p, .team p, .values p, .certifications p {
            font-size: 16px;
            color: #444;
        }
        .highlight {
            color: #28a745;
            font-weight: 600;
        }
        .about-img {
            width: 100%;
            max-width: 450px;
            border-radius: 10px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }
        .about-img:hover {
            transform: scale(1.05);
        }
        @@media (min-width: 768px) {
            .about-img {
                margin: 0 20px 20px 0;
                float: left;
            }
            .row > div {
                clear: none;
            }
        }
        .btn-custom {
            background: linear-gradient(45deg, #28a745, #218838);
            color: #fff;
            padding: 12px 25px;
            border-radius: 25px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            border: none;
        }
        .btn-custom:hover {
            background: linear-gradient(45deg, #218838, #1e7e34);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40,167,69,0.4);
        }
        #newsletter {
            background: linear-gradient(90deg, #28a745, #218838);
            padding: 50px 20px;
            color: #fff;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        #newsletter .newstext h4 {
            font-size: 28px;
            margin-bottom: 15px;
            font-weight: 600;
        }
        #newsletter .newstext p {
            font-size: 16px;
            margin-bottom: 25px;
        }
        #newsletter .form input {
            padding: 12px 20px;
            border: none;
            border-radius: 25px 0 0 25px;
            outline: none;
            width: 250px;
        }
        #newsletter .form button {
            padding: 12px 25px;
            border: none;
            border-radius: 0 25px 25px 0;
            background: #ffd700;
            color: #333;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.3s ease;
        }
        #newsletter .form button:hover {
            background: #e6c200;
            transform: scale(1.05);
        }
        @@media (max-width: 768px) {
            #navbar {
                display: none;
                flex-direction: column;
                position: fixed;
                top: 0;
                right: 0;
                height: 100vh;
width: 250px;
                background: #fff;
                padding: 20px;
                box-shadow: -2px 0 5px rgba(0,0,0,0.2);
                z-index: 1001;
            }
            #navbar.active {
                display: flex;
            }
            #navbar #close {
                display: block;
                position: absolute;
                top: 20px;
                right: 20px;
                color: #333;
                font-size: 24px;
            }
            #mobile {
                display: flex;
            }
            .about-img {
                float: none;
                margin: 20px auto;
            }
            .section-title {
                font-size: 36px;
            }
            #newsletter .form input {
                width: 200px;
            }
        }
        footer {
            background: rgb(238, 238, 238);
            color: #131313;
            padding: 40px 20px;
            text-align: center;
        }
        footer .col {
            margin-bottom: 20px;
        }
        footer h4 {
            font-size: 18px;
            margin-bottom: 15px;
        }
        footer p, footer a {
            font-size: 14px;
            color: #121111;
            text-decoration: none;
        }
        footer a:hover {
            color: #ffd700;
        }
        footer .icon i {
            font-size: 20px;
            margin: 0 10px;
        }
        footer .copyright {
            margin-top: 20px;
            font-size: 12px;
        }
</style>
<section id="about" class="container">
    <div class="about-overlay">
        <h1 class="section-title">Về Chúng Tôi - Fruit-Store</h1>

        <!-- Giới thiệu -->
        <div class="intro row align-items-center">
            <div class="col-md-6">
                <h2>Giới Thiệu Chung</h2>
                <p><span class="highlight">Fruit-Store</span> là thương hiệu hàng đầu trong lĩnh vực cung cấp trái cây tươi ngon, an toàn và chất lượng cao. Với hơn 100 loại trái cây nhập khẩu và nội địa, từ táo Mỹ đến dâu Đà Lạt, chúng tôi mang đến trải nghiệm mua sắm độc đáo và lành mạnh.</p>
                <p>Thành lập với sứ mệnh lan tỏa sức khỏe, Fruit-Store tự hào phục vụ hàng triệu khách hàng với dịch vụ tận tâm và sản phẩm chất lượng hàng đầu.</p>
                <a href="contact.html" class="btn-custom">Liên hệ ngay</a>
            </div>
            <div class="col-md-6">
                <img src="https://cdn.pixabay.com/photo/2015/03/30/19/36/fruit-700007_640.jpg" class="about-img" alt="Fruit-Store Overview">
            </div>
        </div>

        <!-- Lịch sử -->
        <div class="history row align-items-center">
            <div class="col-md-6 order-md-2">
                <h2>Lịch Sử Hình Thành</h2>
                <p>Ra mắt vào năm 2015 tại TP. Hồ Chí Minh, Fruit-Store khởi đầu từ một cửa hàng nhỏ và nay đã mở rộng thành chuỗi với hơn 50 địa điểm. Tính đến <strong>27/06/2025, 12:18 PM +07</strong>, chúng tôi đã phục vụ hơn 1.2 triệu khách hàng và đạt doanh thu 50 triệu USD.</p>
            </div>
            <div class="col-md-6 order-md-1">
                <img src="https://cdn.pixabay.com/photo/2022/05/27/10/35/strawberry-7224875_640.jpg" class="about-img" alt="History">
            </div>
        </div>

        <!-- Đội ngũ -->
        <div class="team row align-items-center">
            <div class="col-md-6">
                <h2>Đội Ngũ Của Chúng Tôi</h2>
                <p>Đội ngũ hơn 350 chuyên gia bao gồm nông nghiệp, logistics và dịch vụ khách hàng 24/7. Với kinh nghiệm 10 năm, chúng tôi cam kết mang đến sự hài lòng tối đa cho khách hàng.</p>
            </div>
            <div class="col-md-6">
                <img src="https://cdn.pixabay.com/photo/2016/07/21/10/05/dragon-fruit-1532127_640.jpg" class="about-img" alt="Team">
            </div>
        </div>

        <!-- Giá trị cốt lõi -->
        <div class="values row align-items-center">
            <div class="col-md-6 order-md-2">
                <h2>Giá Trị Cốt Lõi</h2>
                <ul>
                    <li><strong>Chất lượng:</strong> 100% sản phẩm đạt tiêu chuẩn quốc tế.</li>
                    <li><strong>Tận tâm:</strong> Dịch vụ cá nhân hóa cho từng khách hàng.</li>
                    <li><strong>Bền vững:</strong> Hỗ trợ nông nghiệp hữu cơ và giảm thiểu rác thải.</li>
                </ul>
            </div>
            <div class="col-md-6 order-md-1">
                <img src="https://cdn.pixabay.com/photo/2019/12/13/07/04/fresh-fruits-basket-4692358_640.jpg" class="about-img" alt="Values">
            </div>
        </div>

        <!-- Chứng nhận -->
        <div class="certifications row align-items-center">
            <div class="col-md-6">
                <h2>Chứng Nhận và Đối Tác</h2>
                <p>Fruit-Store đạt ISO 22000, GlobalGAP và hợp tác với VinMart, Shopee, và các nông trại bền vững. Chúng tôi cam kết minh bạch và chất lượng hàng đầu.</p>
            </div>
            <div class="col-md-6">
                <img src="https://cdn.pixabay.com/photo/2020/07/01/16/59/cherries-5360265_640.jpg" class="about-img" alt="Certifications">
            </div>
        </div>
    </div>
</section>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
        // Toggle mobile menu
        const navbar = document.getElementById('navbar');
        const bar = document.getElementById('bar');
        const close = document.getElementById('close');
        if (bar && close && navbar) {
            bar.addEventListener('click', () => navbar.classList.add('active'));
            close.addEventListener('click', () => navbar.classList.remove('active'));
        }

        // Smooth scroll to sections
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href'))?.scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
</script>

